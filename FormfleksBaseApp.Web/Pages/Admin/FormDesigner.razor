@page "/admin/form-designer"
@attribute [Authorize(Policy = "AdminOrHr")]
@inject ApiClient ApiClient

<div class="row g-4">
    @* ── SOL PANEL: FORM TASARIMCISI ── *@
    <div class="col-lg-7">
        @* Header Card *@
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, var(--brand-copper), var(--brand-copper-dark));">
                <div class="d-flex flex-wrap justify-content-between align-items-center">
                    <div>
                        <h1 class="h5 mb-0 text-white fw-bold">
                            <i class="bi bi-columns-gap me-2"></i>Form Tasarım Merkezi
                        </h1>
                        <small class="text-white-50">Alanları tanımlayın, sağ tarafta canlı olarak görün.</small>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-light btn-sm" @onclick="ResetForm">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>Sıfırla
                        </button>
                        <button class="btn btn-light btn-sm text-dark" @onclick="LoadLeaveTemplate">
                            <i class="bi bi-download me-1"></i>Şablon Yükle
                        </button>
                        <button class="btn btn-warning btn-sm fw-bold" @onclick="Save" disabled="@_busy">
                            @if (_busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            <i class="bi bi-cloud-arrow-up me-1"></i>Kaydet
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(_message))
                {
                    <div class="alert alert-success py-2 d-flex align-items-center gap-2">
                        <i class="bi bi-check-circle-fill"></i> @_message
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="alert alert-danger py-2 d-flex align-items-center gap-2">
                        <i class="bi bi-exclamation-triangle-fill"></i> @_error
                    </div>
                }

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold small text-uppercase text-muted">Form Kodu</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text"><i class="bi bi-code-slash"></i></span>
                            <InputText class="form-control" @bind-Value="_model.Code" placeholder="LEAVE_REQUEST" />
                        </div>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label fw-semibold small text-uppercase text-muted">Form Adı</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text"><i class="bi bi-type"></i></span>
                            <InputText class="form-control" @bind-Value="_model.Name" placeholder="İzin Formu" />
                        </div>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check form-switch">
                            <InputCheckbox class="form-check-input" @bind-Value="_model.Active" />
                            <label class="form-check-label fw-semibold small">Kullanıma Açık</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Alan Listesi Card - Bölümler Halinde *@
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h6 mb-0 fw-bold">
                <i class="bi bi-list-nested me-2" style="color: var(--brand-copper);"></i>Form Bölümleri
            </h2>
            <button class="btn btn-sm btn-outline-secondary" @onclick="AddSection">
                <i class="bi bi-layer-forward me-1"></i>Yeni Bölüm Ekle
            </button>
        </div>

        @if (_model.Sections.Count == 0)
        {
            <div class="card border-0 shadow-sm mb-3 text-center p-5 text-muted">
                <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                Hiç bölüm yok. "Yeni Bölüm Ekle" butonuna tıklayarak başlayın.
            </div>
        }

        @for (var sIdx = 0; sIdx < _model.Sections.Count; sIdx++)
        {
            var sec = _model.Sections[sIdx];
            var secIndex = sIdx;
            
            <div class="card border-0 shadow-sm mb-4" style="border-top: 3px solid var(--brand-copper) !important;">
                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-2">
                    <div class="d-flex align-items-center gap-2 flex-grow-1">
                        <i class="bi bi-grip-vertical text-muted cursor-move d-none d-md-block" title="Sürükle"></i>
                        <InputText class="form-control form-control-sm fw-bold border-0 bg-light" @bind-Value="sec.Title" placeholder="Bölüm Başlığı" style="max-width: 300px;" />
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm text-secondary" @onclick="() => MoveSectionUp(secIndex)" disabled="@(secIndex == 0)" title="Yukarı">
                            <i class="bi bi-arrow-up"></i>
                        </button>
                        <button class="btn btn-sm text-secondary" @onclick="() => MoveSectionDown(secIndex)" disabled="@(secIndex == _model.Sections.Count - 1)" title="Aşağı">
                            <i class="bi bi-arrow-down"></i>
                        </button>
                        <button class="btn btn-sm text-danger" @onclick="() => RemoveSection(sec)" title="Bölümü Sil">
                            <i class="bi bi-trash"></i>
                        </button>
                        <button class="btn btn-sm fw-semibold ms-2" style="background: var(--brand-copper-light); color: var(--brand-copper-dark);" @onclick="() => AddField(sec)">
                            <i class="bi bi-plus-lg me-1"></i>Yeni Alan
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0" style="font-size: 0.82rem;">
                            <thead>
                                <tr style="background: var(--bg-light-gray);">
                                    <th class="text-center" style="width:36px">#</th>
                                    <th style="width:110px">Anahtar</th>
                                    <th style="width:140px">Etiket</th>
                                    <th style="width:100px">Veri Tipi</th>
                                    <th class="text-center" style="width:40px">Zor.</th>
                                    <th>Placeholder / Seçenekler</th>
                                    <th class="text-center" style="width:100px">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (sec.Fields.Count == 0)
                                {
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-3">
                                            Bu bölümde henüz alan yok.
                                        </td>
                                    </tr>
                                }
                                @for (var i = 0; i < sec.Fields.Count; i++)
                                {
                                    var f = sec.Fields[i];
                                    var fIndex = i;
                                    <tr>
                                        <td class="text-center text-muted">@(fIndex + 1)</td>
                                        <td><InputText class="form-control form-control-sm form-input-borderless bg-light" @bind-Value="f.FieldKey" placeholder="field_key" /></td>
                                        <td><InputText class="form-control form-control-sm form-input-borderless" @bind-Value="f.Label" placeholder="Görünen İsim" /></td>
                                        <td>
                                            <InputSelect class="form-select form-select-sm form-input-borderless" @bind-Value="f.FieldType">
                                                @foreach (var kvp in FieldTypes)
                                                {
                                                    <option value="@kvp.Key">@kvp.Value</option>
                                                }
                                            </InputSelect>
                                        </td>
                                        <td class="text-center">
                                            <InputCheckbox class="form-check-input" @bind-Value="f.IsRequired" />
                                        </td>
                                        <td>
                                            @if (f.FieldType == 4) // Dropdown ise seçenekler
                                            {
                                                <InputText class="form-control form-control-sm form-input-borderless" @bind-Value="f.OptionsJson" placeholder="A,B,C (virgülle ayırın)" />
                                            }
                                            else
                                            {
                                                <InputText class="form-control form-control-sm form-input-borderless text-muted" @bind-Value="f.Placeholder" placeholder="İpucu metni..." />
                                            }
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm w-100">
                                                <button class="btn btn-outline-secondary" @onclick="() => MoveFieldUp(sec, fIndex)" disabled="@(fIndex == 0)" title="Yukarı">
                                                    <i class="bi bi-chevron-up"></i>
                                                </button>
                                                <button class="btn btn-outline-secondary" @onclick="() => MoveFieldDown(sec, fIndex)" disabled="@(fIndex == sec.Fields.Count - 1)" title="Aşağı">
                                                    <i class="bi bi-chevron-down"></i>
                                                </button>
                                                <button class="btn btn-outline-danger" @onclick="() => RemoveField(sec, f)" title="Sil">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>

    @* ── SAĞ PANEL: CANLI ÖNİZLEME ── *@
    <div class="col-lg-5">
        <div class="sticky-top" style="top: 80px;">
            <div class="card border-0 shadow-sm">
                <div class="card-header border-0 py-2" style="background: var(--brand-copper-dark);">
                    <div class="d-flex align-items-center text-white">
                        <i class="bi bi-eye-fill me-2 fs-5"></i>
                        <h2 class="h6 mb-0 fw-bold text-white">Canlı Önizleme</h2>
                    </div>
                </div>
                <div class="card-body" style="max-height: calc(100vh - 160px); overflow-y: auto; background: #fafbfc;">
                    @if (string.IsNullOrWhiteSpace(_model.Name) && !_model.Sections.SelectMany(s => s.Fields).Any())
                    {
                        <div class="text-center text-muted p-5">
                            <i class="bi bi-layout-text-window fs-1 mb-2"></i>
                            <p class="mb-0">Önizleme burada görünecek</p>
                        </div>
                    }
                    else
                    {
                        <div class="card border border-light shadow-sm">
                            <div class="card-header bg-white border-bottom">
                                <h3 class="h5 mb-0 fw-bold text-dark">@(string.IsNullOrWhiteSpace(_model.Name) ? "İsimsiz Form" : _model.Name)</h3>
                            </div>
                            <div class="card-body p-4">
                                @* DynamicFormRenderer yerine statik görsel önizleme *@
                                @foreach (var sec in _model.Sections.OrderBy(s => s.SortOrder))
                                {
                                    <h4 class="h6 fw-bold mb-3 border-bottom pb-2" style="color: var(--brand-copper-dark);">@sec.Title</h4>
                                    <div class="row g-4 mb-4">
                                        @foreach (var df in sec.Fields.OrderBy(f => f.SortOrder))
                                        {
                                            var colClass = df.FieldType == 2 ? "col-12" : "col-md-6 col-xl-4";
                                            <div class="@colClass">
                                                <EditForm Model="@df">
                                                @if (df.FieldType == 1) // Textbox
                                                {
                                                    <FormfleksBaseApp.Web.Components.Forms.PremiumInput 
                                                        Label="@(df.Label + (df.IsRequired ? " *" : ""))" 
                                                        HelperText="@df.Placeholder" 
                                                        ValueExpression="@(() => df.Label)"
                                                        Disabled="true" 
                                                        IconClass="bi bi-cursor-text" />
                                                }
                                                else if (df.FieldType == 2) // Textarea
                                                {
                                                    <FormfleksBaseApp.Web.Components.Forms.PremiumInput 
                                                        Label="@(df.Label + (df.IsRequired ? " *" : ""))" 
                                                        HelperText="@df.Placeholder" 
                                                        ValueExpression="@(() => df.Label)"
                                                        Disabled="true" 
                                                        Multiline="true" Rows="3" />
                                                }
                                                else if (df.FieldType == 3) // Checkbox
                                                {
                                                    <FormfleksBaseApp.Web.Components.Forms.PremiumCheckbox 
                                                        Label="@(df.Label + (df.IsRequired ? " *" : ""))" 
                                                        HelperText="@df.Placeholder" 
                                                        ValueExpression="@(() => df.IsRequired)"
                                                        Disabled="true" />
                                                }
                                                else if (df.FieldType == 4) // Dropdown
                                                {
                                                    var opts = string.IsNullOrWhiteSpace(df.OptionsJson) ? ["Seçenek 1", "Seçenek 2"] : df.OptionsJson.Split(',', StringSplitOptions.RemoveEmptyEntries);
                                                    <FormfleksBaseApp.Web.Components.Forms.PremiumSelect 
                                                        Label="@(df.Label + (df.IsRequired ? " *" : ""))" 
                                                        HelperText="@df.Placeholder" 
                                                        ValueExpression="@(() => df.Label)"
                                                        Disabled="true" 
                                                        IconClass="bi bi-list-ul">
                                                        @foreach(var o in opts)
                                                        {
                                                            <option>@o.Trim()</option>
                                                        }
                                                    </FormfleksBaseApp.Web.Components.Forms.PremiumSelect>
                                                }
                                                else if (df.FieldType == 5) // Date
                                                {
                                                    <FormfleksBaseApp.Web.Components.Forms.PremiumInput 
                                                        Label="@(df.Label + (df.IsRequired ? " *" : ""))" 
                                                        HelperText="@df.Placeholder" 
                                                        ValueExpression="@(() => df.Label)"
                                                        Type="date" 
                                                        Disabled="true" 
                                                        IconClass="bi bi-calendar" />
                                                }
                                                else if (df.FieldType == 6) // Time
                                                {
                                                    <FormfleksBaseApp.Web.Components.Forms.PremiumInput 
                                                        Label="@(df.Label + (df.IsRequired ? " *" : ""))" 
                                                        HelperText="@df.Placeholder" 
                                                        ValueExpression="@(() => df.Label)"
                                                        Type="time" 
                                                        Disabled="true" 
                                                        IconClass="bi bi-clock" />
                                                }
                                                else if (df.FieldType == 7) // DateTime
                                                {
                                                    <FormfleksBaseApp.Web.Components.Forms.PremiumInput 
                                                        Label="@(df.Label + (df.IsRequired ? " *" : ""))" 
                                                        HelperText="@df.Placeholder" 
                                                        ValueExpression="@(() => df.Label)"
                                                        Type="datetime-local" 
                                                        Disabled="true" 
                                                        IconClass="bi bi-clock-history" />
                                                }
                                                else if (df.FieldType == 10) // File
                                                {
                                                    <FormfleksBaseApp.Web.Components.Forms.PremiumInput 
                                                        Label="@(df.Label + (df.IsRequired ? " *" : ""))" 
                                                        HelperText="@df.Placeholder" 
                                                        ValueExpression="@(() => df.Label)"
                                                        Type="file" 
                                                        Disabled="true" 
                                                        IconClass="bi bi-paperclip" />
                                                }
                                                </EditForm>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@* ── ALT BÖLÜM: MEVCUT FORM TİPLERİ ── *@
<div class="card border-0 shadow-sm mt-4">
    <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-2">
        <h2 class="h6 mb-0 fw-bold">
            <i class="bi bi-collection me-2" style="color: var(--brand-copper);"></i>Sistemdeki Formlar
        </h2>
        <span class="badge bg-light text-dark border">@_templates.Count form şablonu</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead>
                    <tr style="background: var(--bg-light-gray);">
                        <th>Kod</th><th>Ad</th><th class="text-center">Alan</th><th class="text-center">Workflow</th><th>Durum</th><th>Oluşturma</th><th class="text-end pe-3">Aksiyon</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_templates.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-3">
                                <i class="bi bi-inbox me-1"></i>Kayıt bulunamadı
                            </td>
                        </tr>
                    }
                    @foreach (var t in _templates)
                    {
                        <tr>
                            <td class="fw-bold text-brand">@t.Code</td>
                            <td>@t.Name</td>
                            <td class="text-center"><span class="badge bg-light text-dark border">@t.FieldCount alan</span></td>
                            <td class="text-center">
                                @if (t.WorkflowStepCount > 0)
                                {
                                    <span class="badge-status badge-approved">@t.WorkflowStepCount adım</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-draft">Yok</span>
                                }
                            </td>
                            <td>
                                @if (t.Active)
                                {
                                    <span class="badge-status badge-approved"><i class="bi bi-check-circle"></i> Aktif</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-rejected"><i class="bi bi-x-circle"></i> Pasif</span>
                                }
                            </td>
                            <td class="text-muted small">@t.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-end pe-3">
                                <button class="btn btn-sm @(t.Active ? "btn-outline-secondary" : "btn-outline-success")"
                                        disabled="@(_busy || _statusBusyIds.Contains(t.FormTypeId))"
                                        @onclick="() => ToggleTemplateStatusAsync(t)">
                                    @if (_statusBusyIds.Contains(t.FormTypeId))
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    @(t.Active ? "Pasif Yap" : "Aktif Yap")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private FormTemplateEditModel _model = new();
    private IReadOnlyList<FormfleksBaseApp.Web.Models.FormTemplateSummaryDto> _templates = [];
    private string? _message;
    private string? _error;
    private bool _busy;
    private HashSet<Guid> _statusBusyIds = [];

    private static readonly IReadOnlyDictionary<int, string> FieldTypes = new Dictionary<int, string>
    {
        { 1, "Kısa Metin" },
        { 2, "Uzun Metin (Textarea)" },
        { 3, "Onay Kutusu (Checkbox)" },
        { 4, "Açılır Liste (Dropdown)" },
        { 5, "Tarih Seçici" },
        { 6, "Saat Seçici (Time)" },
        { 7, "Tarih ve Saat (DateTime)" },
        { 10, "Dosya Yükleme (File)" }
    };

    protected override async Task OnInitializedAsync()
    {
        await ReloadTemplates();
    }

    private void AddSection()
    {
        _model.Sections.Add(new FormSectionEditModel
        {
            Title = $"Yeni Bölüm {_model.Sections.Count + 1}",
            SortOrder = _model.Sections.Count + 1
        });
        ReindexSectionSortOrder();
    }

    private void RemoveSection(FormSectionEditModel sec)
    {
        _model.Sections.Remove(sec);
        ReindexSectionSortOrder();
    }

    private void ReindexSectionSortOrder()
    {
        for (var i = 0; i < _model.Sections.Count; i++)
        {
            _model.Sections[i].SortOrder = i + 1;
        }
    }

    private void MoveSectionUp(int index)
    {
        if (index <= 0) return;
        var item = _model.Sections[index];
        _model.Sections.RemoveAt(index);
        _model.Sections.Insert(index - 1, item);
        ReindexSectionSortOrder();
    }

    private void MoveSectionDown(int index)
    {
        if (index >= _model.Sections.Count - 1) return;
        var item = _model.Sections[index];
        _model.Sections.RemoveAt(index);
        _model.Sections.Insert(index + 1, item);
        ReindexSectionSortOrder();
    }

    private void AddField(FormSectionEditModel sec)
    {
        int totalFieldCount = _model.Sections.SelectMany(s => s.Fields).Count();
        sec.Fields.Add(new FormFieldEditModel
        {
            FieldKey = $"field_{totalFieldCount + 1}",
            Label = $"Yeni Alan {totalFieldCount + 1}",
            FieldType = 1,
            IsRequired = false
        });
        ReindexFieldSortOrder(sec);
    }

    private void ReindexFieldSortOrder(FormSectionEditModel sec)
    {
        for (var i = 0; i < sec.Fields.Count; i++)
        {
            sec.Fields[i].SortOrder = i + 1;
        }
    }

    private void MoveFieldUp(FormSectionEditModel sec, int index)
    {
        if (index <= 0) return;
        var item = sec.Fields[index];
        sec.Fields.RemoveAt(index);
        sec.Fields.Insert(index - 1, item);
        ReindexFieldSortOrder(sec);
    }

    private void MoveFieldDown(FormSectionEditModel sec, int index)
    {
        if (index >= sec.Fields.Count - 1) return;
        var item = sec.Fields[index];
        sec.Fields.RemoveAt(index);
        sec.Fields.Insert(index + 1, item);
        ReindexFieldSortOrder(sec);
    }

    private void RemoveField(FormSectionEditModel sec, FormFieldEditModel f)
    {
        sec.Fields.Remove(f);
        ReindexFieldSortOrder(sec);
    }

    private async Task Save()
    {
        _message = null;
        _error = null;
        _busy = true;
        try
        {
            if (string.IsNullOrWhiteSpace(_model.Code) || string.IsNullOrWhiteSpace(_model.Name))
            {
                _error = "Form kodu ve adı zorunludur.";
                return;
            }

            // Code uppercase and normalize Turkish chars
            _model.Code = SanitizeCode(_model.Code);

            var allFields = _model.Sections.SelectMany(s => s.Fields).ToList();
            if (allFields.Any(x => string.IsNullOrWhiteSpace(x.FieldKey) || string.IsNullOrWhiteSpace(x.Label)))
            {
                _error = "Tüm alanlar için key ve label zorunludur.";
                return;
            }

            var dtoSections = new List<FormfleksBaseApp.Web.Models.FormTemplateSectionUpsertDto>();
            var dtoFields = new List<FormfleksBaseApp.Web.Models.FormTemplateFieldUpsertDto>();

            foreach (var sec in _model.Sections)
            {
                // Ensure section has a title
                var secTitle = string.IsNullOrWhiteSpace(sec.Title) ? "İsimsiz Bölüm" : sec.Title.Trim();
                
                dtoSections.Add(new FormfleksBaseApp.Web.Models.FormTemplateSectionUpsertDto
                {
                    Title = secTitle,
                    SortOrder = sec.SortOrder
                });

                foreach (var f in sec.Fields)
                {
                    // Serialize Dropdown (Type=4) options properly
                    string? serializedOptions = f.OptionsJson;
                    if (f.FieldType == 4 && !string.IsNullOrWhiteSpace(f.OptionsJson))
                    {
                        var optionsArray = f.OptionsJson.Split(',', StringSplitOptions.RemoveEmptyEntries)
                                                        .Select(opt => new { Value = opt.Trim(), Text = opt.Trim() })
                                                        .ToList();
                        serializedOptions = System.Text.Json.JsonSerializer.Serialize(optionsArray);
                    }

                    dtoFields.Add(new FormfleksBaseApp.Web.Models.FormTemplateFieldUpsertDto
                    {
                        FieldKey = f.FieldKey,
                        Label = string.IsNullOrWhiteSpace(f.Label) ? "İsimsiz Alan" : f.Label,
                        FieldType = f.FieldType,
                        IsRequired = f.IsRequired,
                        SortOrder = f.SortOrder,
                        SectionTitle = secTitle,
                        Placeholder = f.Placeholder,
                        OptionsJson = serializedOptions,
                        Active = true
                    });
                }
            }

            var dto = new FormfleksBaseApp.Web.Models.FormTemplateUpsertDto
            {
                FormTypeId = null,
                Code = _model.Code ?? "PREVIEW",
                Name = string.IsNullOrWhiteSpace(_model.Name) ? "Yeni Tasarım" : _model.Name,
                Active = _model.Active,
                Sections = dtoSections,
                Fields = dtoFields
            };

            var saveResult = await ApiClient.SaveTemplateDetailedAsync(dto, CancellationToken.None);
            if (!saveResult.Success || saveResult.Data is null)
            {
                _error = saveResult.Error ?? "Kayıt başarısız. API yanıtı boş döndü.";
                return;
            }

            _message = "Şablon başarıyla kaydedildi! (Test için veritabanına eklendi)";
            ResetForm();
            await ReloadTemplates();
        }
        catch (Exception ex)
        {
            _error = $"Kayıt hatası: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private string SanitizeCode(string input)
    {
        if (string.IsNullOrWhiteSpace(input)) return "";
        var map = new Dictionary<char, char>
        {
            {'ç','C'}, {'Ç','C'}, {'ğ','G'}, {'Ğ','G'}, {'ı','I'}, {'I','I'}, {'İ','I'}, {'i','I'},
            {'ö','O'}, {'Ö','O'}, {'ş','S'}, {'Ş','S'}, {'ü','U'}, {'Ü','U'}
        };
        var arr = input.Select(c => map.TryGetValue(c, out var repl) ? repl : char.ToUpperInvariant(c)).ToArray();
        return new string(arr).Replace(" ", "_");
    }

    private async Task ToggleTemplateStatusAsync(FormfleksBaseApp.Web.Models.FormTemplateSummaryDto template)
    {
        _message = null;
        _error = null;

        if (_statusBusyIds.Contains(template.FormTypeId))
            return;

        _statusBusyIds.Add(template.FormTypeId);
        try
        {
            var targetStatus = !template.Active;
            var result = await ApiClient.SetTemplateStatusAsync(template.FormTypeId, targetStatus, CancellationToken.None);
            if (!result.Success || result.Data is null)
            {
                _error = result.Error ?? "Form durumu güncellenemedi.";
                return;
            }

            _message = $"{result.Data.Name} formu {(result.Data.Active ? "aktif" : "pasif")} duruma alındı.";
            await ReloadTemplates();
        }
        finally
        {
            _statusBusyIds.Remove(template.FormTypeId);
            StateHasChanged();
        }
    }

    private void ResetForm()
    {
        _model = new FormTemplateEditModel();
        _error = null;
        _message = null;
    }

    private async Task ReloadTemplates()
    {
        try
        {
            var data = await ApiClient.GetTemplatesAsync(CancellationToken.None);
            _templates = data ?? [];
        }
        catch (Exception ex)
        {
            _error = $"Form tipleri yüklenemedi: {ex.Message}";
            _templates = [];
        }
    }

