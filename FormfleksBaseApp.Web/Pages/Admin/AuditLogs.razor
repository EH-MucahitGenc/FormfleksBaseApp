@page "/admin/audit-logs"
@attribute [Authorize(Policy = "AdminOrHr")]
@inject FormfleksBaseApp.Web.Services.ApiClient ApiClient

<div class="page-header d-flex flex-wrap justify-content-between align-items-start gap-3">
    <div>
        <h1>Eylem Geçmişi (Audit Logs)</h1>
        <p class="page-subtitle">Sistem içindeki tüm kritik işlem geçmişini izleyin.</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary" @onclick="LoadLogs" disabled="@_loading">
            <i class="bi bi-arrow-repeat me-1"></i>Yenile
        </button>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius: var(--radius-modern);">
    <div class="card-header bg-white border-bottom py-2">
        <h6 class="mb-0 fw-bold">
            <i class="bi bi-shield-check me-2 text-brand"></i>İşlem Kayıtları
        </h6>
    </div>
    <div class="card-body p-0">
        <DataTable Items="_items" IsLoading="_loading" EmptyStateTitle="Kayıt bulunamadı" EmptyStateDescription="Sistemde henüz bir işlem kaydedilmemiş.">
            <TableHeader>
                <th>Log ID</th>
                <th>Entity Tipi</th>
                <th>Entity ID</th>
                <th>İşlem Tipi</th>
                <th>Kullanıcı ID</th>
                <th>Detay</th>
                <th class="text-end pe-4">Tarih</th>
            </TableHeader>
            <RowTemplate Context="item">
                <td class="small text-muted" style="font-family: monospace;">@item.Id.ToString().Substring(0,8)...</td>
                <td class="fw-semibold">@item.EntityType</td>
                <td class="small text-muted" style="font-family: monospace;">@item.EntityId.ToString().Substring(0,8)...</td>
                <td>
                    @if (item.ActionType == "FormSubmitted")
                    {
                        <span class="badge bg-primary">Form İletildi</span>
                    }
                    else if (item.ActionType == "Approved")
                    {
                        <span class="badge bg-success">Onaylandı</span>
                    }
                    else if (item.ActionType == "Rejected")
                    {
                        <span class="badge bg-danger">Reddedildi</span>
                    }
                    else if (item.ActionType == "ReturnedForRevision")
                    {
                        <span class="badge bg-warning text-dark">Revizyona Gönderildi</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@item.ActionType</span>
                    }
                </td>
                <td class="small text-muted" style="font-family: monospace;">@(item.ActorUserId?.ToString().Substring(0,8) ?? "Sistem")</td>
                <td>
                    @if (!string.IsNullOrWhiteSpace(item.DetailJson))
                    {
                        <button class="btn btn-sm btn-light border py-0 px-2" @onclick="() => ShowDetails(item.DetailJson)" title="Detay">
                            <i class="bi bi-code-slash text-muted"></i> JSON
                        </button>
                    }
                </td>
                <td class="text-end pe-3 text-muted small">@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td>
            </RowTemplate>
        </DataTable>
    </div>
</div>

@if (_isModalOpen)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow" style="border-radius: var(--radius-modern);">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title fw-bold"><i class="bi bi-info-circle me-2 text-brand"></i>Log Detayı</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body bg-light">
                    <pre class="mb-0 p-3 bg-white border rounded" style="font-size: 0.85rem; max-height: 400px; overflow-y: auto;">@_modalContent</pre>
                </div>
                <div class="modal-footer border-top bg-white">
                    <button type="button" class="btn btn-secondary px-4" @onclick="CloseModal">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private IReadOnlyList<FormfleksBaseApp.Contracts.DynamicForms.AuditLogs.AuditLogItemDto> _items = [];

    private bool _isModalOpen;
    private string _modalContent = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        _loading = true;
        try
        {
            _items = await ApiClient.GetAuditLogsAsync(CancellationToken.None);
        }
        catch { /* silent */ }
        finally { _loading = false; }
    }

    private void ShowDetails(string json)
    {
        try
        {
            // Basit formatlama
            var parsed = System.Text.Json.JsonDocument.Parse(json);
            _modalContent = System.Text.Json.JsonSerializer.Serialize(parsed, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            _modalContent = json;
        }
        _isModalOpen = true;
    }

    private void CloseModal()
    {
        _isModalOpen = false;
        _modalContent = "";
    }
}
