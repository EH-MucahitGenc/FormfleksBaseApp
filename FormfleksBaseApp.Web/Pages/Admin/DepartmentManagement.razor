@page "/admin/departments"
@using Microsoft.AspNetCore.Authorization
@using FormfleksBaseApp.Application.Features.AdminDepartments.Commands.CreateDepartment
@using FormfleksBaseApp.Application.Features.AdminDepartments.Commands.UpdateDepartment
@using FormfleksBaseApp.Application.Features.AdminDepartments.Dtos
@inject FormfleksBaseApp.Web.Services.ApiClient ApiClient
@attribute [Authorize(Policy = "AdminOrHr")]

@if (!string.IsNullOrWhiteSpace(_successMsg))
{
    <div class="alert alert-success alert-dismissible fade show py-2 d-flex align-items-center gap-2 mb-3" role="alert">
        <i class="bi bi-check-circle-fill"></i> @_successMsg
        <button type="button" class="btn-close btn-sm" @onclick="() => _successMsg = null"></button>
    </div>
}
@if (!string.IsNullOrWhiteSpace(_errorMsg))
{
    <div class="alert alert-danger alert-dismissible fade show py-2 d-flex align-items-center gap-2 mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i> @_errorMsg
        <button type="button" class="btn-close btn-sm" @onclick="() => _errorMsg = null"></button>
    </div>
}

<AppPageHeader Title="Departman Yönetimi" Subtitle="Kurumsal departmanları yönetin ve listeye yeni departmanlar ekleyin." />

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yükleniyor...</span>
        </div>
    </div>
}
else
{
    <div class="shadow-sm border rounded">
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain" CssClass="px-2 py-1 border-bottom">
            <DxToolbarItem Text="Yeni Departman" BeginGroup="true" IconCssClass="bi bi-plus-lg" Click="OpenCreateModal" />
            <DxToolbarItem Text="Sütun Seçici" BeginGroup="true" IconCssClass="bi bi-layout-three-columns" CssClass="col-chooser-btn" Click='@(() => _grid.ShowColumnChooser(".col-chooser-btn"))' />
        </DxToolbar>

        <DxGrid @ref="_grid"
                Data="@_departments" 
                ShowFilterRow="true" 
                ShowGroupPanel="false" 
                ShowSearchBox="true" 
                PageSize="15" 
                PagerVisible="true"
                AllowSelectRowByClick="true"
                SelectionMode="GridSelectionMode.Multiple"
                ColumnResizeMode="GridColumnResizeMode.NextColumn"
                CssClass="w-100 border-0">
            <Columns>
                <DxGridDataColumn FieldName="Code" Caption="Departman Kodu" MinWidth="180">
                    <CellDisplayTemplate Context="deptContext">
                        @{ var d = (AdminDepartmentDto)deptContext.DataItem; }
                        <span class="ff-cell-primary">@d.Code</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="Name" Caption="Departman Adı" MinWidth="250" />
                <DxGridDataColumn FieldName="Active" Caption="Durum" MinWidth="150">
                    <CellDisplayTemplate Context="deptContext">
                        @{ var d = (AdminDepartmentDto)deptContext.DataItem; }
                        <AppStatusBadge IsBooleanMode="true" Active="d.Active" />
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn Caption="İşlem" AllowFilter="false" AllowSort="false" MinWidth="120" Width="120px">
                    <CellDisplayTemplate Context="deptContext">
                        @{ var d = (AdminDepartmentDto)deptContext.DataItem; }
                        <div class="d-flex gap-2">
                            <button class="ff-action-btn" title="Düzenle" @onclick="() => OpenEditModal(d)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="ff-action-btn text-danger" title="Sil" @onclick="() => ConfirmDelete(d)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>
        </DxGrid>
    </div>
}

@* ===== EKLE/DÜZENLE POPUP ===== *@
<DxPopup Visible="@_showModal" 
         VisibleChanged="@((bool v) => _showModal = v)" 
         HeaderText="@(_editId.HasValue ? "Departman Düzenle" : "Yeni Departman Ekle")" 
         Width="500px" 
         ShowCloseButton="true">
    <BodyTemplate>
        <div class="mb-3">
            <label class="form-label small text-muted text-uppercase fw-semibold">Departman Kodu</label>
            <input type="text" class="form-control" @bind="_editCode" placeholder="Örn: IT" />
            <small class="text-muted">Sistemde benzersiz olmalıdır.</small>
        </div>
        <div class="mb-3">
            <label class="form-label small text-muted text-uppercase fw-semibold">Departman Adı</label>
            <input type="text" class="form-control" @bind="_editName" placeholder="Örn: Bilgi Teknolojileri" />
        </div>
        <div class="form-check form-switch mt-4">
            <input class="form-check-input" type="checkbox" id="deptActive" @bind="_editActive">
            <label class="form-check-label ms-2" for="deptActive">Bu departman sistemde aktif olsun</label>
        </div>
    </BodyTemplate>
    <FooterTemplate>
        <button type="button" class="btn btn-light border" @onclick="CloseModal">İptal</button>
        <button type="button" class="btn btn-primary ms-2" @onclick="Save" disabled="@_saving">
            @if (_saving) { <span class="spinner-border spinner-border-sm me-2"></span> } Kaydet
        </button>
    </FooterTemplate>
</DxPopup>

@* ===== SİLME ONAY POPUP ===== *@
<AppConfirmPopup @bind-Visible="_showDeleteModal"
                 Title="Departmanı Sil"
                 Message="@($"{_deleteDepartment?.Name} departmanını silmek istediğinize emin misiniz?")"
                 SubMessage="Bu departmana kayıtlı kullanıcılar varsa hata alırsınız."
                 ConfirmButtonText="Evet, Sil"
                 IsProcessing="_saving"
                 OnConfirm="Delete"
                 OnCancel="CloseDeleteModal" />
}

@code {
    IGrid _grid;
    private bool _loading = true;
    private IReadOnlyList<AdminDepartmentDto> _departments = [];
    private string? _successMsg;
    private string? _errorMsg;

    private bool _showModal;
    private bool _saving;
    private Guid? _editId;
    private string _editCode = "";
    private string _editName = "";
    private bool _editActive = true;

    private bool _showDeleteModal;
    private AdminDepartmentDto? _deleteDepartment;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _departments = await ApiClient.GetAdminDepartmentsAsync(CancellationToken.None);
        _loading = false;
        StateHasChanged();
    }

    private void OpenCreateModal()
    {
        _errorMsg = null;
        _successMsg = null;
        _editId = null;
        _editCode = "";
        _editName = "";
        _editActive = true;
        _showModal = true;
    }

    private void OpenEditModal(AdminDepartmentDto department)
    {
        _errorMsg = null;
        _successMsg = null;
        _editId = department.Id;
        _editCode = department.Code;
        _editName = department.Name;
        _editActive = department.Active;
        _showModal = true;
    }

    private void CloseModal() => _showModal = false;

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_editCode) || string.IsNullOrWhiteSpace(_editName))
        {
            _errorMsg = "Departman Kodu ve Adı zorunludur.";
            _showModal = false;
            return;
        }

        _saving = true;
        _errorMsg = null;
        _successMsg = null;

        if (_editId.HasValue)
        {
            // Update
            var cmd = new UpdateDepartmentCommand
            {
                Code = _editCode,
                Name = _editName,
                Active = _editActive
            };
            var res = await ApiClient.UpdateDepartmentAsync(_editId.Value, cmd, CancellationToken.None);
            if (res.Success)
            {
                _successMsg = "Departman başarıyla güncellendi.";
                _showModal = false;
                await LoadData();
            }
            else
            {
                _errorMsg = res.Error ?? "Güncelleme başarısız.";
            }
        }
        else
        {
            // Create
            var cmd = new CreateDepartmentCommand
            {
                Code = _editCode,
                Name = _editName,
                Active = _editActive
            };
            var res = await ApiClient.CreateDepartmentAsync(cmd, CancellationToken.None);
            if (res.Success)
            {
                _successMsg = "Departman başarıyla eklendi.";
                _showModal = false;
                await LoadData();
            }
            else
            {
                _errorMsg = res.Error ?? "Kayıt başarısız.";
            }
        }

        _saving = false;
    }

    private void ConfirmDelete(AdminDepartmentDto department)
    {
        _errorMsg = null;
        _successMsg = null;
        _deleteDepartment = department;
        _showDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        _showDeleteModal = false;
        _deleteDepartment = null;
    }

    private async Task Delete()
    {
        if (_deleteDepartment == null) return;

        _saving = true;
        var res = await ApiClient.DeleteDepartmentAsync(_deleteDepartment.Id, CancellationToken.None);
        
        if (res.Success)
        {
            _successMsg = "Departman başarıyla silindi.";
            _showDeleteModal = false;
            await LoadData();
        }
        else
        {
            _errorMsg = res.Error ?? "Silme işlemi başarısız. Bu departman kullanımda olabilir.";
            _showDeleteModal = false;
        }

        _saving = false;
    }
}
