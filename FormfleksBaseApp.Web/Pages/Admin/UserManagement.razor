@page "/admin/users"
@using Microsoft.AspNetCore.Authorization
@inject FormfleksBaseApp.Web.Services.ApiClient ApiClient
@attribute [Authorize(Policy = "AdminOnly")]

<AppPageHeader Title="Kullanıcı Yönetimi" Subtitle="Sistemdeki tüm kullanıcıları, rollerini ve durumlarını yönetin." />

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yükleniyor...</span>
        </div>
    </div>
}
else
{
    <div class="shadow-sm border rounded">
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain" CssClass="px-2 py-1 border-bottom">
            <DxToolbarItem Text="Sütun Seçici" BeginGroup="false" IconCssClass="bi bi-layout-three-columns" CssClass="col-chooser-btn" Click='@(() => _grid.ShowColumnChooser(".col-chooser-btn"))' />
        </DxToolbar>

        <DxGrid @ref="_grid"
                Data="@_users" 
                ShowFilterRow="true" 
                ShowGroupPanel="false" 
                ShowSearchBox="true" 
                PageSize="15" 
                PagerVisible="true"
                AllowSelectRowByClick="true"
                SelectionMode="GridSelectionMode.Multiple"
                ColumnResizeMode="GridColumnResizeMode.NextColumn"
                CssClass="w-100 border-0">
            <Columns>
                <DxGridDataColumn FieldName="Name" Caption="Ad Soyad" MinWidth="250">
                    <CellDisplayTemplate Context="userCtx">
                        @{ var u = (FormfleksBaseApp.Web.Services.AdminUserDto)userCtx.DataItem; }
                        <div class="d-flex align-items-center">
                            <div class="avatar rounded-circle me-3 d-flex justify-content-center align-items-center text-white fw-bold" style="width: 32px; height: 32px; font-size: 0.8rem; background: linear-gradient(135deg, var(--brand-copper), var(--brand-copper-dark));">
                                @(u.Name.Length > 0 ? u.Name.Substring(0, 1).ToUpper() : "?")
                            </div>
                            <span class="fw-medium ff-cell-primary">@u.Name</span>
                        </div>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="Email" Caption="E-Posta" MinWidth="220" />
                <DxGridDataColumn Caption="Rol / Yetki Grupları" AllowFilter="false" AllowSort="false" MinWidth="200">
                    <CellDisplayTemplate Context="userCtx">
                        @{ var u = (FormfleksBaseApp.Web.Services.AdminUserDto)userCtx.DataItem; }
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var role in u.Roles)
                            {
                                <span class="badge rounded-pill" style="background: var(--brand-copper-light); color: var(--brand-copper-dark); border: 1px solid rgba(215,108,60,0.2);">@role</span>
                            }
                        </div>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="IsActive" Caption="Durum" MinWidth="120">
                    <CellDisplayTemplate Context="userCtx">
                        @{ var u = (FormfleksBaseApp.Web.Services.AdminUserDto)userCtx.DataItem; }
                        <AppStatusBadge IsBooleanMode="true" Active="u.IsActive" />
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn Caption="İşlem" AllowFilter="false" AllowSort="false" MinWidth="120" Width="120px">
                    <CellDisplayTemplate Context="userCtx">
                        @{ var u = (FormfleksBaseApp.Web.Services.AdminUserDto)userCtx.DataItem; }
                        <div class="d-flex gap-2">
                            <button class="ff-action-btn" title="Düzenle" @onclick="() => OpenEditModal(u)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="ff-action-btn text-danger" title="Sil" @onclick="() => ConfirmDelete(u)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>
        </DxGrid>
    </div>
}

@* ===== DÜZENLEME POPUP ===== *@
<DxPopup Visible="@_showEditModal" 
         VisibleChanged="@((bool v) => _showEditModal = v)" 
         HeaderText="Kullanıcıyı Düzenle" 
         Width="550px" 
         ShowCloseButton="true">
    <BodyTemplate>
        <DxFormLayout CssClass="w-100">
            <DxFormLayoutItem Caption="E-Posta" ColSpanMd="12">
                <Template Context="formLayoutCtx">
                    <InputText class="form-control bg-light" value="@_editUser?.Email" disabled />
                    <small class="text-muted d-block mt-1">E-Posta adresi güncellenemez.</small>
                </Template>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Ad Soyad" ColSpanMd="12">
                <Template Context="formLayoutCtx">
                    <DxTextBox @bind-Text="_editName" NullText="Kullanıcının adı soyadı..." />
                </Template>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Yetki / Rol" ColSpanMd="12">
                <Template Context="formLayoutCtx">
                    <DxComboBox Data="@_allRoles"
                                TextFieldName="Name"
                                ValueFieldName="Id"
                                @bind-Value="@_editRoleId"
                                NullText="— Rol Seçin —"
                                CssClass="w-100" />
                    <small class="text-muted d-block mt-1">Kullanıcının sisteme giriş yetki seviyesi.</small>
                </Template>
            </DxFormLayoutItem>
        </DxFormLayout>
    </BodyTemplate>
    <FooterTemplate>
        <button type="button" class="btn btn-light border" @onclick="CloseEditModal">İptal</button>
        <button type="button" class="btn btn-primary ms-2" @onclick="SaveEdit" disabled="@_saving">
            @if (_saving) { <span class="spinner-border spinner-border-sm me-2"></span> } Kaydet
        </button>
    </FooterTemplate>
</DxPopup>

@* ===== SİLME ONAY POPUP ===== *@
<AppConfirmPopup @bind-Visible="_showDeleteModal"
                 Title="Kullanıcıyı Sil"
                 Message="@($"{_deleteUser?.Name} kullanıcısını pasif duruma almak istediğinize emin misiniz?")"
                 ConfirmButtonText="Evet, Sil"
                 IsProcessing="_saving"
                 OnConfirm="ExecuteDelete"
                 OnCancel="CloseDeleteModal" />

@code {
    IGrid _grid;
    private bool _loading = true;
    private List<FormfleksBaseApp.Web.Services.AdminUserDto> _users = [];
    private IReadOnlyList<FormfleksBaseApp.Application.Features.AdminRoles.Dtos.AdminRoleDto> _allRoles = [];
    private string? _successMsg;
    private string? _errorMsg;
    private bool _saving;

    // Edit modal
    private bool _showEditModal;
    private FormfleksBaseApp.Web.Services.AdminUserDto? _editUser;
    private string _editName = "";
    private Guid _editRoleId = Guid.Empty;

    // Delete modal
    private bool _showDeleteModal;
    private FormfleksBaseApp.Web.Services.AdminUserDto? _deleteUser;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
        _allRoles = await ApiClient.GetAdminRolesAsync(CancellationToken.None);
    }

    private async Task LoadUsers()
    {
        _loading = true;
        try
        {
            _users = (await ApiClient.GetUsersAsync(CancellationToken.None)).ToList();
        }
        catch (Exception ex)
        {
            _errorMsg = "Kullanıcılar yüklenirken hata oluştu: " + ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    // ── DÜZENLEME ──
    private void OpenEditModal(FormfleksBaseApp.Web.Services.AdminUserDto user)
    {
        _editUser = user;
        _editName = user.Name;
        // Kullanıcının mevcut rolünü bul
        var currentRoleName = user.Roles.FirstOrDefault();
        var matchedRole = _allRoles.FirstOrDefault(r =>
            string.Equals(r.Name, currentRoleName, StringComparison.OrdinalIgnoreCase));
        _editRoleId = matchedRole?.Id ?? Guid.Empty;
        _showEditModal = true;
        _successMsg = null;
        _errorMsg = null;
    }

    private void CloseEditModal()
    {
        _showEditModal = false;
        _editUser = null;
    }

    private async Task SaveEdit()
    {
        if (_editUser is null) return;

        _saving = true;
        try
        {
            var req = new FormfleksBaseApp.Web.Services.UpdateUserRequest
            {
                DisplayName = _editName,
                RoleIds = _editRoleId != Guid.Empty ? [_editRoleId] : null
            };

            var ok = await ApiClient.UpdateUserAsync(_editUser.Id, req, CancellationToken.None);
            if (ok)
            {
                _successMsg = $"\"{_editName}\" başarıyla güncellendi.";
                CloseEditModal();
                await LoadUsers();
            }
            else
            {
                _errorMsg = "Güncelleme başarısız oldu. Lütfen tekrar deneyin.";
            }
        }
        catch (Exception ex)
        {
            _errorMsg = $"Hata: {ex.Message}";
        }
        finally { _saving = false; }
    }

    // ── SİLME ──
    private void ConfirmDelete(FormfleksBaseApp.Web.Services.AdminUserDto user)
    {
        _deleteUser = user;
        _showDeleteModal = true;
        _successMsg = null;
        _errorMsg = null;
    }

    private void CloseDeleteModal()
    {
        _showDeleteModal = false;
        _deleteUser = null;
    }

    private async Task ExecuteDelete()
    {
        if (_deleteUser is null) return;

        _saving = true;
        try
        {
            var ok = await ApiClient.DeleteUserAsync(_deleteUser.Id, CancellationToken.None);
            if (ok)
            {
                _successMsg = $"\"{_deleteUser.Name}\" pasif duruma alındı.";
                CloseDeleteModal();
                await LoadUsers();
            }
            else
            {
                _errorMsg = "Silme işlemi başarısız oldu.";
            }
        }
        catch (Exception ex)
        {
            _errorMsg = $"Hata: {ex.Message}";
        }
        finally { _saving = false; }
    }
}
