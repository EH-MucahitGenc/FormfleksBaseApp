@page "/admin/roles"
@using Microsoft.AspNetCore.Authorization
@using FormfleksBaseApp.Application.Features.AdminRoles.Commands.CreateRole
@using FormfleksBaseApp.Application.Features.AdminRoles.Commands.UpdateRole
@using FormfleksBaseApp.Application.Features.AdminRoles.Dtos
@inject FormfleksBaseApp.Web.Services.ApiClient ApiClient
@attribute [Authorize(Policy = "AdminOrHr")]

@if (!string.IsNullOrWhiteSpace(_successMsg))
{
    <div class="alert alert-success alert-dismissible fade show py-2 d-flex align-items-center gap-2 mb-3" role="alert">
        <i class="bi bi-check-circle-fill"></i> @_successMsg
        <button type="button" class="btn-close btn-sm" @onclick="() => _successMsg = null"></button>
    </div>
}
@if (!string.IsNullOrWhiteSpace(_errorMsg))
{
    <div class="alert alert-danger alert-dismissible fade show py-2 d-flex align-items-center gap-2 mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i> @_errorMsg
        <button type="button" class="btn-close btn-sm" @onclick="() => _errorMsg = null"></button>
    </div>
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Rol Yönetimi</h1>
        <p class="text-muted mb-0">Sistem yetki rolleri tanımlarını yapın ve durumlarını güncelleyin.</p>
    </div>
</div>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yükleniyor...</span>
        </div>
    </div>
}
else
{
    <div class="shadow-sm border rounded">
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain" CssClass="px-2 py-1 border-bottom">
            <DxToolbarItem Text="Yeni Rol" BeginGroup="true" IconCssClass="bi bi-plus-lg" Click="OpenCreateModal" />
            <DxToolbarItem Text="Sütun Seçici" BeginGroup="true" IconCssClass="bi bi-layout-three-columns" CssClass="col-chooser-btn" Click="@(() => _grid.ShowColumnChooser(".col-chooser-btn"))" />
        </DxToolbar>

        <DxGrid @ref="_grid"
                Data="@_roles" 
                ShowFilterRow="true" 
                ShowGroupPanel="false" 
                ShowSearchBox="true" 
                PageSize="15" 
                PagerVisible="true"
                AllowSelectRowByClick="true"
                SelectionMode="GridSelectionMode.Multiple"
                ColumnResizeMode="GridColumnResizeMode.NextColumn"
                CssClass="w-100 border-0">
            <Columns>
                <DxGridDataColumn FieldName="Code" Caption="Rol Kodu" MinWidth="180">
                    <CellDisplayTemplate Context="roleContext">
                        @{ var r = (AdminRoleDto)roleContext.DataItem; }
                        <span class="ff-cell-primary">@r.Code</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="Name" Caption="Rol Adı" MinWidth="250" />
                <DxGridDataColumn FieldName="Active" Caption="Durum" MinWidth="150">
                    <CellDisplayTemplate Context="roleContext">
                        @{ var r = (AdminRoleDto)roleContext.DataItem; }
                        @if (r.Active)
                        {
                            <span class="ff-status-badge -success">Aktif</span>
                        }
                        else
                        {
                            <span class="ff-status-badge -draft">Pasif</span>
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn Caption="İşlem" AllowFilter="false" AllowSort="false" MinWidth="120" Width="120px">
                    <CellDisplayTemplate Context="roleContext">
                        @{ var r = (AdminRoleDto)roleContext.DataItem; }
                        <div class="d-flex gap-2">
                            <button class="ff-action-btn" title="Düzenle" @onclick="() => OpenEditModal(r)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="ff-action-btn text-danger" title="Sil" @onclick="() => ConfirmDelete(r)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>
        </DxGrid>
    </div>
}

@* ===== EKLE/DÜZENLE MODAL ===== *@
@if (_showModal)
{
    <div class="modal-backdrop fade show" style="z-index: 1050;"></div>
    <div class="modal fade show d-block" tabindex="-1" style="z-index: 1055;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: var(--ff-border-radius-lg);">
                <div class="modal-header bg-light border-bottom py-3">
                    <h5 class="modal-title fw-bold">@(_editId.HasValue ? "Rol Düzenle" : "Yeni Rol Ekle")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body py-4">
                    <div class="mb-3">
                        <label class="form-label small text-muted text-uppercase fw-semibold">Rol Kodu</label>
                        <input type="text" class="form-control" @bind="_editCode" placeholder="Örn: HR_MANAGER" />
                        <small class="text-muted">Sistemde benzersiz olmalıdır ve boşluk içermemesi önerilir.</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted text-uppercase fw-semibold">Rol Adı</label>
                        <input type="text" class="form-control" @bind="_editName" placeholder="Örn: İnsan Kaynakları Yöneticisi" />
                    </div>
                    <div class="form-check form-switch mt-4">
                        <input class="form-check-input" type="checkbox" id="roleActive" @bind="_editActive">
                        <label class="form-check-label ms-2" for="roleActive">Bu rol sistemde aktif olsun</label>
                    </div>
                </div>
                <div class="modal-footer border-top bg-light">
                    <button type="button" class="btn btn-light border" @onclick="CloseModal">İptal</button>
                    <button type="button" class="btn btn-primary" @onclick="Save" disabled="@_saving">
                        @if (_saving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ===== SİLME ONAY MODAL ===== *@
@if (_showDeleteModal && _deleteRole is not null)
{
    <div class="modal-backdrop fade show" style="z-index: 1050;"></div>
    <div class="modal fade show d-block" tabindex="-1" style="z-index: 1055;">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow-lg" style="border-radius: var(--ff-border-radius-lg);">
                <div class="modal-header bg-danger text-white border-0 py-3">
                    <h5 class="modal-title fw-bold">Rolü Sil</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseDeleteModal"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <i class="bi bi-exclamation-circle text-danger mb-3" style="font-size: 3rem;"></i>
                    <p class="mb-0"><strong>@_deleteRole.Name</strong> rolünü silmek istediğinize emin misiniz?</p>
                    <p class="small text-muted mt-2">Bu işlem geri alınamaz ve role atamalı kullanıcılar varsa hata verecektir.</p>
                </div>
                <div class="modal-footer border-0 justify-content-center bg-light">
                    <button type="button" class="btn btn-light border" @onclick="CloseDeleteModal">Vazgeç</button>
                    <button type="button" class="btn btn-danger px-4" @onclick="Delete" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        Evet, Sil
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    IGrid _grid;
    private bool _loading = true;
    private IReadOnlyList<AdminRoleDto> _roles = [];
    private string? _successMsg;
    private string? _errorMsg;

    private bool _showModal;
    private bool _saving;
    private Guid? _editId;
    private string _editCode = "";
    private string _editName = "";
    private bool _editActive = true;

    private bool _showDeleteModal;
    private AdminRoleDto? _deleteRole;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _roles = await ApiClient.GetAdminRolesAsync(CancellationToken.None);
        _loading = false;
        StateHasChanged();
    }

    private void OpenCreateModal()
    {
        _errorMsg = null;
        _successMsg = null;
        _editId = null;
        _editCode = "";
        _editName = "";
        _editActive = true;
        _showModal = true;
    }

    private void OpenEditModal(AdminRoleDto role)
    {
        _errorMsg = null;
        _successMsg = null;
        _editId = role.Id;
        _editCode = role.Code;
        _editName = role.Name;
        _editActive = role.Active;
        _showModal = true;
    }

    private void CloseModal() => _showModal = false;

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_editCode) || string.IsNullOrWhiteSpace(_editName))
        {
            _errorMsg = "Rol Kodu ve Adı zorunludur.";
            _showModal = false;
            return;
        }

        _saving = true;
        _errorMsg = null;
        _successMsg = null;

        if (_editId.HasValue)
        {
            // Update
            var cmd = new UpdateRoleCommand
            {
                Code = _editCode,
                Name = _editName,
                Active = _editActive
            };
            var res = await ApiClient.UpdateRoleAsync(_editId.Value, cmd, CancellationToken.None);
            if (res.Success)
            {
                _successMsg = "Rol başarıyla güncellendi.";
                _showModal = false;
                await LoadData();
            }
            else
            {
                _errorMsg = res.Error ?? "Güncelleme başarısız.";
            }
        }
        else
        {
            // Create
            var cmd = new CreateRoleCommand
            {
                Code = _editCode,
                Name = _editName,
                Active = _editActive
            };
            var res = await ApiClient.CreateRoleAsync(cmd, CancellationToken.None);
            if (res.Success)
            {
                _successMsg = "Rol başarıyla eklendi.";
                _showModal = false;
                await LoadData();
            }
            else
            {
                _errorMsg = res.Error ?? "Kayıt başarısız.";
            }
        }

        _saving = false;
    }

    private void ConfirmDelete(AdminRoleDto role)
    {
        _errorMsg = null;
        _successMsg = null;
        _deleteRole = role;
        _showDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        _showDeleteModal = false;
        _deleteRole = null;
    }

    private async Task Delete()
    {
        if (_deleteRole == null) return;

        _saving = true;
        var res = await ApiClient.DeleteRoleAsync(_deleteRole.Id, CancellationToken.None);
        
        if (res.Success)
        {
            _successMsg = "Rol başarıyla silindi.";
            _showDeleteModal = false;
            await LoadData();
        }
        else
        {
            _errorMsg = res.Error ?? "Silme işlemi başarısız. Bu rol kullanımda olabilir.";
            _showDeleteModal = false;
        }

        _saving = false;
    }
}
