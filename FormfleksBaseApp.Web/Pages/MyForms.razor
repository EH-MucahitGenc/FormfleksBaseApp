@page "/my-forms"
@attribute [Authorize(Policy = "HasAppRole")]
@inject FormfleksBaseApp.Web.Services.ApiClient ApiClient

<AppPageHeader Title="Form Talepleri" Subtitle="Gönderdiğiniz tüm form taleplerini buradan takip edebilirsiniz.">
    <a href="/forms/create" class="btn btn-primary d-flex align-items-center gap-2">
        <i class="bi bi-plus-lg"></i> Yeni Form
    </a>
</AppPageHeader>

@if (_loading)
{
    <div class="d-flex justify-content-center p-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yükleniyor...</span>
        </div>
    </div>
}
else
{
    <div class="shadow-sm border rounded">
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain" CssClass="px-2 py-1 border-bottom">
            <DxToolbarItem Text="Sütun Seçici" BeginGroup="true" IconCssClass="bi bi-layout-three-columns" CssClass="col-chooser-btn" Click='@(() => _grid.ShowColumnChooser(".col-chooser-btn"))' />
        </DxToolbar>
        
        <DxGrid @ref="_grid"
                Data="@_items" 
                ShowFilterRow="true" 
                ShowGroupPanel="true" 
                ShowSearchBox="true" 
                PageSize="10" 
                PagerVisible="true" 
                PageSizeSelectorVisible="true" 
                PageSizeSelectorItems="@(new int[] { 10, 20, 50, 100 })"
                AllowSelectRowByClick="true"
                SelectionMode="GridSelectionMode.Multiple"
                ColumnResizeMode="GridColumnResizeMode.NextColumn"
                CssClass="w-100 border-0">
            <Columns>
                <DxGridDataColumn FieldName="RequestNo" Caption="Talep No" MinWidth="180">
                    <CellDisplayTemplate>
                        @{ var item = (FormfleksBaseApp.Web.Models.MyFormRequestListItemDto)context.DataItem; }
                        @if(item.Status == 1)
                        {
                            <a href="/forms/request/@item.RequestId" class="text-decoration-none ff-cell-primary d-flex align-items-center gap-2">
                                <span>@item.RequestNo</span>
                                <i class="bi bi-pencil-square text-muted" style="font-size: 0.85rem;"></i>
                            </a>
                        }
                        else
                        {
                            <span class="ff-cell-primary">@item.RequestNo</span>
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="FormTypeName" Caption="Form Tipi" MinWidth="200" />
                <DxGridDataColumn FieldName="Status" Caption="Durum" MinWidth="160">
                    <CellDisplayTemplate>
                        @{ var item = (FormfleksBaseApp.Web.Models.MyFormRequestListItemDto)context.DataItem; }
                        <AppStatusBadge Status="(int)item.Status" />
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="CurrentStepNo" Caption="Adım" MinWidth="120">
                    <CellDisplayTemplate>
                        @{ var item = (FormfleksBaseApp.Web.Models.MyFormRequestListItemDto)context.DataItem; }
                        @if(item.CurrentStepNo.HasValue)
                        {
                            <span class="badge" style="background-color: var(--ff-bg-hover); color: var(--ff-text-secondary); border: 1px solid var(--ff-border); font-weight: 500;">Adım @item.CurrentStepNo</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="CreatedAt" Caption="Tarih" MinWidth="180">
                    <CellDisplayTemplate>
                        @{ var item = (FormfleksBaseApp.Web.Models.MyFormRequestListItemDto)context.DataItem; }
                        <span class="ff-cell-muted">@item.CreatedAt.AddHours(3).ToString("dd.MM.yyyy HH:mm")</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>
        </DxGrid>
    </div>
}

@code {
    IGrid _grid;
    [SupplyParameterFromQuery(Name = "status")] 
    public int? StatusFilter { get; set; }

    private bool _loading = true;
    private IReadOnlyList<FormfleksBaseApp.Web.Models.MyFormRequestListItemDto> _items = [];

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            _loading = true;
            var data = await ApiClient.GetMyRequestsAsync(CancellationToken.None);
            if (StatusFilter.HasValue)
            {
                _items = data.Where(x => x.Status == StatusFilter.Value).ToList();
            }
            else
            {
                _items = data;
            }
        }
        catch { /* silent */ }
        finally { _loading = false; }
    }


}
