@page "/login"
@layout LoginLayout
@using FormfleksBaseApp.Web.Auth
@inject FormfleksBaseApp.Web.Services.ApiClient ApiClient
@inject FormfleksBaseApp.Web.Auth.AuthTokenStore TokenStore
@inject FormfleksBaseApp.Web.Auth.AppAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<div class="login-card premium-card">
    <div class="premium-card-body p-4 p-md-5">
        <div class="text-center mb-4">
            <img src="/images/logo.png" alt="Logo" style="max-height: 48px;" class="mb-3" />
            <h2 class="h4 fw-bold text-main">Kurumsal Portal</h2>
            <p class="text-muted">Devam etmek için Active Directory hesabınızla giriş yapın.</p>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span style="font-size: 0.9rem;">@_error</span>
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />
            
            <FfInput Label="Kullanıcı Adı"
                     @bind-Value="_model.Username"
                     Placeholder="ornek.kullanici"
                     Class="mb-3" />

            <FfInput Label="Şifre"
                     @bind-Value="_model.Password"
                     Type="password"
                     Placeholder="••••••••"
                     Class="mb-4" />

            <FfButton Type="submit"
                      Variant="primary"
                      Class="w-100 py-2"
                      IsLoading="_loading"
                      LoadingText="Giriş yapılıyor...">
                Giriş Yap
            </FfButton>
        </EditForm>
    </div>
</div>

@code {
    private LoginModel _model = new();
    private string? _error;
    private bool _loading;

    private async Task HandleLogin()
    {
        _error = null;
        _loading = true;

        try
        {
            var request = new FormfleksBaseApp.Contracts.Auth.LoginRequest
            {
                Username = _model.Username,
                Password = _model.Password
            };

            var result = await ApiClient.AdLoginAsync(request, CancellationToken.None);
            if (result.Success && result.Data is not null)
            {
                var (userId, roles, _) = JwtTokenParser.Parse(result.Data.Token);
                if (roles.Count == 0)
                {
                    _error = "Bu hesap için herhangi bir rol tanımı bulunamadı. Lütfen yönetici ile iletişime geçin.";
                    await AuthStateProvider.MarkLoggedOutAsync();
                    return;
                }

                await AuthStateProvider.MarkAuthenticatedAsync(
                    result.Data.Token,
                    _model.Username,
                    userId,
                    roles.Distinct(StringComparer.OrdinalIgnoreCase).ToArray());
                Navigation.NavigateTo("/dashboard", forceLoad: false);
            }
            else
            {
                _error = result.Error ?? "Giriş başarısız. Lütfen bilgilerinizi kontrol edin.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Bağlantı hatası: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private sealed class LoginModel
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
