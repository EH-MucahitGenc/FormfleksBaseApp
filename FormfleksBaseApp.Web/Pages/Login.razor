@page "/login"
@layout LoginLayout
@using FormfleksBaseApp.Web.Auth
@inject FormfleksBaseApp.Web.Services.ApiClient ApiClient
@inject FormfleksBaseApp.Web.Auth.AuthTokenStore TokenStore
@inject FormfleksBaseApp.Web.Auth.AppAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<div class="login-card-wrapper">
    <div class="text-center mb-5">
        <img src="/images/logo.svg" alt="Formfleks" style="height: 40px; margin-bottom: 2rem;" />
        <div class="d-flex justify-content-center mb-3">
            <div style="width: 70px; height: 70px; border-radius: 50%; background-color: var(--ff-bg-hover); display: flex; align-items: center; justify-content: center;">
                <i class="bi bi-person-fill" style="color: var(--ff-primary); font-size: 2.5rem;"></i>
            </div>
        </div>
        <h2 class="login-title" style="letter-spacing: 2px;">HOŞ GELDİNİZ</h2>
        <p class="login-subtitle">Devam etmek için hesap bilgilerinizi giriniz.</p>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="login-alert" role="alert">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
            <div>@_error</div>
        </div>
    }

    <EditForm Model="_model" OnValidSubmit="HandleLogin">
        <DataAnnotationsValidator />
        
        <div class="mb-4">
            <label class="login-form-label">Kullanıcı Adı</label>
            <DxTextBox @bind-Text="@_model.Username"
                       NullText="ornek.kullanici"
                       ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                       CssClass="w-100" />
            <ValidationMessage For="@(() => _model.Username)" class="text-danger mt-1" style="font-size:0.8rem;" />
        </div>

        <div class="mb-5">
            <label class="login-form-label">Şifre</label>
            <DxTextBox @bind-Text="@_model.Password"
                       Password="true"
                       NullText="••••••••"
                       ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                       CssClass="w-100" />
            <ValidationMessage For="@(() => _model.Password)" class="text-danger mt-1" style="font-size:0.8rem;" />
        </div>

        <DxButton SubmitFormOnClick="true"
                  Text="@(_loading ? "Giriş yapılıyor..." : "Giriş Yap")"
                  RenderStyle="ButtonRenderStyle.Primary"
                  CssClass="w-100 py-2 fs-6 fw-bold"
                  Enabled="@(!_loading)" />
    </EditForm>
</div>

@code {
    private LoginModel _model = new();
    private string? _error;
    private bool _loading;

    private async Task HandleLogin()
    {
        _error = null;
        _loading = true;

        try
        {
            var request = new FormfleksBaseApp.Contracts.Auth.LoginRequest
            {
                Username = _model.Username,
                Password = _model.Password
            };

            var result = await ApiClient.AdLoginAsync(request, CancellationToken.None);
            if (result.Success && result.Data is not null)
            {
                var (userId, roles, _) = JwtTokenParser.Parse(result.Data.Token);
                
                // If the user has no specific roles assigned via AD sync, we will map a default "User" role for UI logic
                var userRoles = roles.ToList();
                if (userRoles.Count == 0)
                {
                    userRoles.Add("User");
                }

                await AuthStateProvider.MarkAuthenticatedAsync(
                    result.Data.Token,
                    _model.Username,
                    userId,
                    userRoles.Distinct(StringComparer.OrdinalIgnoreCase).ToArray());
                Navigation.NavigateTo("/dashboard", forceLoad: false);
            }
            else
            {
                _error = result.Error ?? "Giriş başarısız. Lütfen bilgilerinizi kontrol edin.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Bağlantı hatası: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private sealed class LoginModel
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
