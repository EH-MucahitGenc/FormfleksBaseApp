@page "/forms/{FormCode}"
@page "/forms/leave"
@page "/forms/request/{RequestId:guid}"
@attribute [Authorize(Policy = "HasAppRole")]
@inject ApiClient ApiClient
@inject FormfleksBaseApp.Web.Auth.AuthTokenStore TokenStore

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h1 class="fw-bold mb-1" style="color: var(--ff-text-main); font-size: 1.8rem; letter-spacing: -0.5px;">@_formTitle</h1>
        <div class="text-muted d-flex align-items-center gap-2" style="font-size: 0.9rem;">
            <i class="bi bi-folder2-open" style="color: var(--ff-primary);"></i>
            <span>Formlarım</span> 
            <i class="bi bi-chevron-right" style="font-size: 0.7rem;"></i> 
            <span class="fw-medium" style="color: var(--ff-text-secondary);">@_formTitle</span>
        </div>
    </div>
    @if (RequestId.HasValue)
    {
        <div class="px-3 py-1 fw-bold text-uppercase d-flex align-items-center gap-2" style="background-color: var(--ff-bg-surface); border: 1px solid var(--ff-border); border-radius: 50px; color: var(--ff-text-secondary); font-size: 0.8rem; box-shadow: var(--ff-shadow-sm);">
            <div style="width: 8px; height: 8px; border-radius: 50%; background-color: var(--ff-warning);"></div>
            İnceleniyor
        </div>
    }
</div>

<div class="alert d-flex align-items-center gap-3 mb-4 shadow-sm" style="background-color: var(--ff-bg-surface); border: 1px solid var(--ff-border); border-left: 4px solid var(--ff-info); border-radius: var(--ff-border-radius-lg);">
    <i class="bi bi-info-circle-fill fs-3" style="color: var(--ff-info);"></i>
    <div style="color: var(--ff-text-secondary); font-size: 0.95rem;">
        <strong class="d-block" style="color: var(--ff-text-main);">Bilgilendirme</strong>
        @_formSubtitle
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-xl-11">
        <div class="ff-card shadow-lg border-0" style="border-radius: var(--ff-border-radius-lg);">
            <div class="ff-card-header bg-white" style="border-bottom: 2px solid var(--ff-bg-body); padding: 1.5rem 2rem;">
                <h6 class="mb-0 fw-bold d-flex align-items-center" style="font-size: 1.15rem; color: var(--ff-text-main);">
                    <i class="bi bi-ui-checks-grid me-3 fs-4" style="color: var(--ff-primary);"></i>Form Kayıt Detayları
                </h6>
            </div>
            <div class="ff-card-body p-4 p-md-5" style="background-color: #FAFCFF;">
                @if (_loading)
                {
                    <div class="text-center py-5">
                        <div class="spinner-grow text-primary mb-3" style="width: 3rem; height: 3rem; opacity: 0.5;" role="status"></div>
                        <h5 class="fw-bold text-muted">Form Hazırlanıyor...</h5>
                    </div>
                }
                else if (_definition is null)
                {
                    <div class="alert alert-warning py-4 px-4 d-flex align-items-center gap-3 rounded-4">
                        <i class="bi bi-exclamation-triangle-fill fs-2"></i> 
                        <div>
                            <strong class="d-block mb-1">Şablon Bulunamadı</strong>
                            Aradığınız form şablonu pasif durumda veya silinmiş olabilir. Lütfen yönetici ile iletişime geçin.
                        </div>
                    </div>
                }
                else
                {
                    <EditForm EditContext="@_editContext" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />
                        
                        @* Dinamik Form Render - Premium Styling *@
                        @foreach (var sec in _definition.Sections.OrderBy(s => s.SortOrder))
                        {
                            <div class="mb-5 bg-white p-4 p-md-5 rounded-4 shadow-sm border" style="border-color: var(--ff-border) !important;">
                                <h4 class="fw-bold mb-4 pb-3" style="color: var(--ff-text-main); border-bottom: 2px solid var(--ff-bg-body);">
                                    @sec.Title
                                </h4>
                                
                                <DxFormLayout CssClass="w-100">
                                    @foreach (var field in sec.Fields.OrderBy(f => f.SortOrder))
                                    {
                                        <DxFormLayoutItem ColSpanMd="12" CssClass="mb-3">
                                            <Template Context="formLayoutCtx">
                                                @{
                                                    // Dinamik modelden mevcut değeri al
                                                    _formData.TryGetValue(field.Key, out var val);
                                                    var safeStringVal = val?.ToString() ?? string.Empty;
                                                    var safeBoolVal = bool.TryParse(safeStringVal, out var bVal) ? bVal : false;
                                                    var labelWithStar = field.Label + (field.IsRequired ? " *" : "");
                                                }

                                                @if (field.FieldType == 1) // Textbox
                                                {
                                                    <FormfleksBaseApp.Web.Components.Forms.PremiumInput 
                                                        Label="@labelWithStar" HelperText="@field.Placeholder"
                                                        Value="@safeStringVal" ValueChanged="@((string s) => UpdateFieldValue(field.Key, s))" 
                                                        ValueExpression="@( () => safeStringVal )" 
                                                        Disabled="@_isReadOnly" IconClass="bi bi-cursor-text" />
                                                }
                                                else if (field.FieldType == 2) // Textarea
                                                {
                                                    <FormfleksBaseApp.Web.Components.Forms.PremiumInput 
                                                        Label="@labelWithStar" HelperText="@field.Placeholder" Multiline="true"
                                                        Value="@safeStringVal" ValueChanged="@((string s) => UpdateFieldValue(field.Key, s))" 
                                                        ValueExpression="@( () => safeStringVal )" 
                                                        Disabled="@_isReadOnly" Rows="3" />
                                                }
                                                else if (field.FieldType == 3) // Checkbox
                                                {
                                                    <FormfleksBaseApp.Web.Components.Forms.PremiumCheckbox 
                                                        Label="@labelWithStar" HelperText="@field.Placeholder"
                                                        Value="@safeBoolVal" ValueChanged="@((bool b) => UpdateFieldValue(field.Key, b ? "true" : "false"))"
                                                        ValueExpression="@( () => safeBoolVal )"
                                                        Disabled="@_isReadOnly" />
                                                }
                                                else if (field.FieldType == 4) // Dropdown
                                                {
                                                    var opts = GetDropdownOptions(field.OptionsJson);
                                                        
                                                    <FormfleksBaseApp.Web.Components.Forms.PremiumSelect 
                                                        Label="@labelWithStar" HelperText="@field.Placeholder"
                                                        Value="@safeStringVal" ValueChanged="@((string s) => UpdateFieldValue(field.Key, s))"
                                                        ValueExpression="@( () => safeStringVal )"
                                                        Disabled="@_isReadOnly" IconClass="bi bi-list-ul">
                                                        @foreach(var o in opts)
                                                        {
                                                            <option value="@o">@o</option>
                                                        }
                                                    </FormfleksBaseApp.Web.Components.Forms.PremiumSelect>
                                                }
                                                else if (field.FieldType == 5) // Date
                                                {
                                                    <FormfleksBaseApp.Web.Components.Forms.PremiumInput 
                                                        Label="@labelWithStar" HelperText="@field.Placeholder" Type="date"
                                                        Value="@safeStringVal" ValueChanged="@((string s) => UpdateFieldValue(field.Key, s))" 
                                                        ValueExpression="@( () => safeStringVal )" 
                                                        Disabled="@_isReadOnly" IconClass="bi bi-calendar" />
                                                }
                                                else if (field.FieldType == 6) // Time
                                                {
                                                    <FormfleksBaseApp.Web.Components.Forms.PremiumInput 
                                                        Label="@labelWithStar" HelperText="@field.Placeholder" Type="time"
                                                        Value="@safeStringVal" ValueChanged="@((string s) => UpdateFieldValue(field.Key, s))" 
                                                        ValueExpression="@( () => safeStringVal )" 
                                                        Disabled="@_isReadOnly" IconClass="bi bi-clock" />
                                                }
                                                else if (field.FieldType == 7) // DateTime
                                                {
                                                    <FormfleksBaseApp.Web.Components.Forms.PremiumInput 
                                                        Label="@labelWithStar" HelperText="@field.Placeholder" Type="datetime-local"
                                                        Value="@safeStringVal" ValueChanged="@((string s) => UpdateFieldValue(field.Key, s))" 
                                                        ValueExpression="@( () => safeStringVal )" 
                                                        Disabled="@_isReadOnly" IconClass="bi bi-clock-history" />
                                                }
                                                
                                                @* Hata mesajını EditContext'ten alıp gösterelim *@
                                                <div class="text-danger small mt-1">
                                                    @foreach(var msg in _editContext.GetValidationMessages(new FieldIdentifier(_model, field.Key)))
                                                    {
                                                        <span>@msg</span><br/>
                                                    }
                                                </div>
                                            </Template>
                                        </DxFormLayoutItem>
                                    }
                                </DxFormLayout>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(_message))
                        {
                            <div class="alert mt-3 py-2 d-flex align-items-center gap-2" style="background-color: var(--ff-success); color: white; border-radius: var(--ff-border-radius);">
                                <i class="bi bi-check-circle-fill"></i> @_message
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_error))
                        {
                            <div class="alert alert-danger mt-3 py-2">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i> @_error
                            </div>
                        }

                        @if (!_isReadOnly)
                        {
                            <div class="d-flex justify-content-end gap-3 mt-5 px-4 py-3 sticky-bottom" style="background-color: var(--ff-bg-surface); border-top: 1px solid var(--ff-border); border-radius: 0 0 var(--ff-border-radius-lg) var(--ff-border-radius-lg); margin-left: -3rem; margin-right: -3rem; margin-bottom: -3rem; box-shadow: 0 -4px 15px rgba(0,0,0,0.03);">
                                <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                                          RenderStyleMode="ButtonRenderStyleMode.Outline"
                                          Text="Taslak Kaydet"
                                          Click="SaveDraft"
                                          Enabled="@(!_busy)"
                                          CssClass="px-5 py-2 fw-semibold" />

                                <DxButton RenderStyle="ButtonRenderStyle.Primary"
                                          RenderStyleMode="ButtonRenderStyleMode.Contained"
                                          Text="Onayı Başlat"
                                          SubmitFormOnClick="true"
                                          IconCssClass="bi bi-send-fill"
                                          Enabled="@(!_busy)"
                                          CssClass="px-5 py-2 fw-bold" />
                            </div>
                        }
                    </EditForm>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        @if (_definition is not null)
        {
            <div class="card border-0 shadow-sm sticky-top" style="top: 80px; border-radius: var(--radius-modern);">
                <div class="card-header bg-white border-bottom py-3" style="border-radius: var(--radius-modern) var(--radius-modern) 0 0;">
                    <h6 class="mb-0 fw-bold">
                        <i class="bi bi-info-circle me-2" style="color: var(--brand-copper);"></i>Form Bilgileri
                    </h6>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-3">
                            <span class="text-muted small text-uppercase fw-semibold d-block">Form Tipi</span>
                            <span class="fw-bold fs-6">@_definition.Name</span>
                        </li>
                        <li class="mb-3">
                            <span class="text-muted small text-uppercase fw-semibold d-block">Durum</span>
                            <span class="badge-status badge-draft mt-1">@(RequestId.HasValue ? "İnceleniyor" : "Yeni Kayıt")</span>
                        </li>
                    </ul>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public string? FormCode { get; set; }

    [Parameter]
    public Guid? RequestId { get; set; }

    private bool _loading = true;
    private bool _busy;
    private string? _message;
    private string? _error;
    private bool _isReadOnly = false;
    private string _formTitle = "Yeni Kayıt";
    private string _formSubtitle = "Lütfen form alanlarını eksiksiz doldurun.";

    private FormfleksBaseApp.Web.Models.FormDefinitionDto? _definition;
    private Dictionary<string, object> _formData = new();
    
    // Geçici model (EditForm için)
    private DynamicFormModel _model = new();
    private EditContext _editContext = default!;

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_model);
    }

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            _loading = true;
            _message = null;
            _error = null;
            _formData.Clear();
            _model.Fields.Clear();

            var codeToLoad = FormCode ?? "LEAVE_REQ";
            if (!RequestId.HasValue && string.IsNullOrWhiteSpace(FormCode) && NavigationManager.Uri.EndsWith("/forms/leave"))
            {
                codeToLoad = "LEAVE_REQ";
            }

            if (RequestId.HasValue)
            {
                var reqRes = await ApiClient.GetRequestDetailedAsync(RequestId.Value, CancellationToken.None);
                if (reqRes != null)
                {
                    codeToLoad = reqRes.FormTypeCode;
                    foreach (var v in reqRes.Values)
                    {
                        _formData[v.FieldKey] = v.ValueText ?? string.Empty;
                    }
                }
                else
                {
                    _error = "Form kaydı bulunamadı.";
                    return;
                }
            }

            await LoadDefinition(codeToLoad);
            
            _formTitle = _definition?.Name ?? "Form Kaydı";
            _formSubtitle = RequestId.HasValue ? "Mevcut kaydı görüntülüyorsunuz." : "Yeni form dolduruluyor.";
        }
        catch (Exception ex)
        {
            _error = "Form yüklenirken hata oluştu: " + ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadDefinition(string code)
    {
        // Gerçek API çağrısı
        var result = await ApiClient.GetFormDefinitionDetailedAsync(code, CancellationToken.None);
        if (result.Success && result.Data is not null)
        {
            _definition = result.Data;
        }
        else
        {
            _error = result.Error ?? "Form tanımı bulunamadı.";
            _definition = null;
        }
    }

    private void UpdateFieldValue(string key, object? val)
    {
        if (val is null)
            _formData.Remove(key);
        else
            _formData[key] = val;
            
        // EditContext validasyonu için dummy obje tetiklemesi yapılabilir (gerekirse)
        var fieldId = new FieldIdentifier(_model, key);
        _editContext.NotifyFieldChanged(fieldId);
    }

    private IEnumerable<string> GetDropdownOptions(string? optionsJson)
    {
        if (string.IsNullOrWhiteSpace(optionsJson)) return [];
        
        try
        {
            if (optionsJson.TrimStart().StartsWith("["))
            {
                var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var parsed = System.Text.Json.JsonSerializer.Deserialize<List<Dictionary<string, object>>>(optionsJson, options);
                
                if (parsed != null)
                {
                    return parsed.Select(x => 
                    {
                        var textKey = x.Keys.FirstOrDefault(k => string.Equals(k, "text", StringComparison.OrdinalIgnoreCase));
                        var valKey = x.Keys.FirstOrDefault(k => string.Equals(k, "value", StringComparison.OrdinalIgnoreCase));
                        
                        if (textKey != null && x[textKey] != null) return x[textKey].ToString() ?? "";
                        if (valKey != null && x[valKey] != null) return x[valKey].ToString() ?? "";
                        
                        return "";
                    }).Where(x => !string.IsNullOrEmpty(x));
                }
            }
        }
        catch
        {
            // Ignore parse errors and fallback
        }
        
        return optionsJson.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(o => o.Trim());
    }

    private async Task HandleValidSubmit()
    {
        _error = null;
        
        // Custom backend Validation - Zorunlu alan kontrolü
        if (_definition is not null)
        {
            var errors = new List<string>();
            foreach(var sec in _definition.Sections)
            {
                foreach(var field in sec.Fields.Where(f => f.IsRequired))
                {
                    if (!_formData.TryGetValue(field.Key, out var val) || string.IsNullOrWhiteSpace(val?.ToString()))
                    {
                        errors.Add($"{field.Label} alanı zorunludur.");
                    }
                }
            }
            if (errors.Any())
            {
                _error = string.Join(" ", errors);
                return;
            }
        }

        await SubmitForm();
    }

    private async Task SubmitForm()
    {
        if (_definition is null) return;
        _busy = true;
        _message = null;
        
        try
        {
            var valuesDict = _formData.Select(kvp => new FormfleksBaseApp.Web.Models.UpsertFormRequestItemDto
            {
                FieldKey = kvp.Key,
                ValueText = kvp.Value?.ToString()
            }).ToList();

            var draftReq = new FormfleksBaseApp.Web.Models.SaveDraftRequestDto
            {
                RequestId = RequestId,
                FormTypeId = _definition.FormTypeId,
                RequestorUserId = TokenStore.UserId ?? Guid.Empty,
                Values = valuesDict
            };

            var draftRes = await ApiClient.SaveDraftDetailedAsync(draftReq, CancellationToken.None);
            if (!draftRes.Success || draftRes.Data is null)
            {
                _error = "Taslak kaydedilemedi: " + draftRes.Error;
                return;
            }

            var subReq = new FormfleksBaseApp.Web.Models.SubmitRequestDto
            {
                RequestId = draftRes.Data.RequestId,
                ActorUserId = TokenStore.UserId ?? Guid.Empty,
                ConcurrencyToken = draftRes.Data.ConcurrencyToken
            };

            var subRes = await ApiClient.SubmitDetailedAsync(subReq, CancellationToken.None);
            if (subRes.Success)
            {
                _message = "Form başarıyla onaya gönderildi!";
                _isReadOnly = true;
                _formData.Clear();
            }
            else
            {
                _error = "Hata: " + subRes.Error;
            }
        }
        catch(Exception ex)
        {
            _error = ex.Message;
        }
        finally { _busy = false; }
    }

    private async Task SaveDraft()
    {
        if (_definition is null) return;
        _busy = true;
        _message = null;
        
        try
        {
            var valuesDict = _formData.Select(kvp => new FormfleksBaseApp.Web.Models.UpsertFormRequestItemDto
            {
                FieldKey = kvp.Key,
                ValueText = kvp.Value?.ToString()
            }).ToList();

            var draftReq = new FormfleksBaseApp.Web.Models.SaveDraftRequestDto
            {
                RequestId = RequestId,
                FormTypeId = _definition.FormTypeId,
                RequestorUserId = TokenStore.UserId ?? Guid.Empty,
                Values = valuesDict
            };

            var draftRes = await ApiClient.SaveDraftDetailedAsync(draftReq, CancellationToken.None);
             if (draftRes.Success && draftRes.Data is not null)
            {
                _message = "Taslak kaydedildi!";
                RequestId = draftRes.Data.RequestId;
            }
            else
            {
                _error = "Hata: " + draftRes.Error;
            }
        }
        catch(Exception ex)
        {
            _error = ex.Message;
        }
        finally { _busy = false; }
    }

    [Inject] public NavigationManager NavigationManager { get; set; } = default!;

    // EditForm desteği için basit bir model sarmalayıcı
    private class DynamicFormModel
    {
        public Dictionary<string, string> Fields { get; set; } = new();
    }
}
