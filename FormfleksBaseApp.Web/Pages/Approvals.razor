@page "/approvals"
@attribute [Authorize(Policy = "HasAppRole")]
@inject FormfleksBaseApp.Web.Services.ApiClient ApiClient
@inject FormfleksBaseApp.Web.Auth.AuthTokenStore TokenStore

<AppPageHeader Title="Bekleyen Onaylar" Subtitle="Size atanan bekleyen onay talepleri." />

@if (_loading)
{
    <div class="d-flex justify-content-center p-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yükleniyor...</span>
        </div>
    </div>
}
else
{
    <div class="shadow-sm border rounded">
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain" CssClass="px-2 py-1 border-bottom">
            <DxToolbarItem Text="Sütun Seçici" BeginGroup="true" IconCssClass="bi bi-layout-three-columns" CssClass="col-chooser-btn" Click='@(() => _grid.ShowColumnChooser(".col-chooser-btn"))' />
        </DxToolbar>

        <DxGrid @ref="_grid"
                Data="@_items" 
                ShowFilterRow="true" 
                ShowGroupPanel="true" 
                ShowSearchBox="true" 
                PageSize="15" 
                PagerVisible="true" 
                PageSizeSelectorVisible="true" 
                PageSizeSelectorItems="@(new int[] { 15, 30, 50 })"
                AllowSelectRowByClick="true"
                SelectionMode="GridSelectionMode.Multiple"
                ColumnResizeMode="GridColumnResizeMode.NextColumn"
                CssClass="w-100 border-0">
            <Columns>
                <DxGridDataColumn FieldName="RequestNo" Caption="Talep No" MinWidth="180">
                    <CellDisplayTemplate>
                        @{ var item = (FormfleksBaseApp.Web.Models.PendingApprovalListItemDto)context.DataItem; }
                        <span class="ff-cell-primary">@item.RequestNo</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="FormTypeName" Caption="Form Tipi" MinWidth="200" />
                <DxGridDataColumn FieldName="StepNo" Caption="Adım" MinWidth="120">
                    <CellDisplayTemplate>
                        @{ var item = (FormfleksBaseApp.Web.Models.PendingApprovalListItemDto)context.DataItem; }
                        <span class="badge" style="background-color: var(--ff-bg-hover); color: var(--ff-text-secondary); border: 1px solid var(--ff-border); font-weight: 500;">Adım @item.StepNo</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="CreatedAt" Caption="Tarih" MinWidth="180">
                    <CellDisplayTemplate>
                        @{ var item = (FormfleksBaseApp.Web.Models.PendingApprovalListItemDto)context.DataItem; }
                        <span class="ff-cell-muted">@item.CreatedAt.AddHours(3).ToString("dd.MM.yyyy HH:mm")</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn Caption="İşlem" AllowFilter="false" AllowSort="false" MinWidth="280">
                    <CellDisplayTemplate>
                        @{ var item = (FormfleksBaseApp.Web.Models.PendingApprovalListItemDto)context.DataItem; }
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-success px-3 rounded-pill fw-medium border-0 d-flex align-items-center gap-1 shadow-sm" @onclick="() => OpenActionModal(item, 1)">
                                <i class="bi bi-check2"></i> Onayla
                            </button>
                            <button class="btn btn-sm btn-danger px-3 rounded-pill fw-medium border-0 d-flex align-items-center gap-1 shadow-sm" @onclick="() => OpenActionModal(item, 2)">
                                <i class="bi bi-x-lg"></i> Reddet
                            </button>
                            <button class="btn btn-sm btn-secondary px-3 rounded-pill fw-medium border-0 d-flex align-items-center gap-1 shadow-sm" @onclick="() => OpenActionModal(item, 3)">
                                <i class="bi bi-arrow-return-left"></i> İade
                            </button>
                        </div>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>
        </DxGrid>
    </div>
}

@if (_isModalOpen && _selectedItem is not null)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow" style="border-radius: var(--radius-modern);">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title fw-bold">
                        @if (_selectedActionType == 1) { <i class="bi bi-check-circle-fill text-success me-2"></i> @("Onayla") }
                        else if (_selectedActionType == 2) { <i class="bi bi-x-circle-fill text-danger me-2"></i> @("Reddet") }
                        else { <i class="bi bi-arrow-return-left text-warning me-2"></i> @("İade Et") }
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseActionModal"></button>
                </div>
                <div class="modal-body bg-light">
                    <p class="mb-2 text-muted small"><strong>@_selectedItem.RequestNo</strong> numaralı talebe işlem yapıyorsunuz.</p>
                    <label class="form-label fw-semibold">
                        Yorum / Açıklama @( _selectedActionType == 1 ? "(Opsiyonel)" : "(Zorunlu)" )
                    </label>
                    <textarea class="form-control" rows="3" @bind="_actionComment" placeholder="İşlem nedenini buraya yazabilirsiniz..."></textarea>
                </div>
                <div class="modal-footer border-top bg-white">
                    <button type="button" class="btn btn-outline-secondary px-4" @onclick="CloseActionModal" disabled="@_busy">Vazgeç</button>
                    <button type="button" class="btn @GetActionBtnClass()" px-4 @onclick="ConfirmAction" disabled="@(_busy || !IsCommentValid())">
                        @if (_busy)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert mt-3 mb-0 d-flex align-items-center gap-2" style="border-radius: var(--radius-modern); background: var(--status-info-bg); color: var(--status-info); border: 1px solid rgba(59, 130, 246, 0.2);">
        <i class="bi bi-info-circle"></i> @_message
    </div>
}

@code {
    IGrid _grid;
    private bool _loading = true;
    private bool _busy = false;
    private string? _message;
    private IReadOnlyList<FormfleksBaseApp.Web.Models.PendingApprovalListItemDto> _items = [];

    private bool _isModalOpen;
    private FormfleksBaseApp.Web.Models.PendingApprovalListItemDto? _selectedItem;
    private int _selectedActionType;
    private string _actionComment = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        try
        {
            _items = await ApiClient.GetPendingApprovalsAsync(CancellationToken.None);
        }
        catch { /* silent */ }
        finally { _loading = false; }
    }

    private void OpenActionModal(FormfleksBaseApp.Web.Models.PendingApprovalListItemDto item, int actionType)
    {
        _selectedItem = item;
        _selectedActionType = actionType;
        _actionComment = "";
        _message = null;
        _isModalOpen = true;
    }

    private void CloseActionModal()
    {
        _isModalOpen = false;
        _selectedItem = null;
        _actionComment = "";
    }

    private bool IsCommentValid()
    {
        if (_selectedActionType == 2 || _selectedActionType == 3) // Red veya İade ise yorum zorunlu
        {
            return !string.IsNullOrWhiteSpace(_actionComment);
        }
        return true;
    }

    private string GetActionBtnClass()
    {
        return _selectedActionType switch
        {
            1 => "btn-success",
            2 => "btn-danger",
            3 => "btn-warning",
            _ => "btn-primary"
        };
    }

    private async Task ConfirmAction()
    {
        if (!TokenStore.UserId.HasValue || _selectedItem is null) return;
        if (!IsCommentValid()) return;

        _busy = true;

        try
        {
            var dto = new FormfleksBaseApp.Web.Models.ApprovalActionRequestDto
            {
                RequestId = _selectedItem.RequestId,
                ApprovalId = _selectedItem.ApprovalId,
                ActorUserId = TokenStore.UserId.Value,
                ApprovalConcurrencyToken = _selectedItem.ApprovalConcurrencyToken,
                ActionType = _selectedActionType,
                Comment = _actionComment
            };

            await ApiClient.ExecuteApprovalActionAsync(dto, CancellationToken.None);
            _message = _selectedActionType switch
            {
                1 => "Talep başarıyla onaylandı.",
                2 => "Talep reddedildi.",
                3 => "Talep revizyona iade edildi.",
                _ => "İşlem tamamlandı."
            };

            CloseActionModal();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _message = $"İşlem başarısız: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }
}
