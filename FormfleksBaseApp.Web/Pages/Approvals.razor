@page "/approvals"
@attribute [Authorize(Policy = "HasAppRole")]
@inject FormfleksBaseApp.Web.Services.ApiClient ApiClient
@inject FormfleksBaseApp.Web.Auth.AuthTokenStore TokenStore

<div class="page-header">
    <h1>Onay Bekleyenler</h1>
    <p class="page-subtitle">Size atanan bekleyen onay talepleri.</p>
</div>

<div class="card border-0 shadow-sm" style="border-radius: var(--radius-modern);">
    <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-2" style="border-radius: var(--radius-modern) var(--radius-modern) 0 0;">
        <h6 class="mb-0 fw-bold">
            <i class="bi bi-clock-history me-2" style="color: var(--brand-copper);"></i>Bekleyen Onaylar
        </h6>
        <span class="badge bg-light text-dark border">@_items.Count talep</span>
    </div>
    <div class="card-body p-0">
        <DataTable Items="_items" IsLoading="_loading" EmptyStateTitle="Tüm işlemleriniz güncel!" EmptyStateDescription="Bekleyen onay talebiniz bulunmuyor.">
            <TableHeader>
                <th>Talep No</th>
                <th>Form Tipi</th>
                <th>Adım</th>
                <th>Tarih</th>
                <th class="text-end pe-4">İşlem</th>
            </TableHeader>
            <RowTemplate Context="item">
                <td class="fw-bold">@item.RequestNo</td>
                <td>@item.FormTypeName</td>
                <td><span class="badge-status badge-approval">Adım @item.StepNo</span></td>
                <td class="text-muted small">@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td class="text-end pe-3">
                    <div class="d-flex gap-2 justify-content-end">
                        <button class="btn btn-sm btn-outline-success d-flex align-items-center gap-1" 
                                style="border-radius: var(--radius-sm);"
                                title="Onayla"
                                @onclick="() => OpenActionModal(item, 1)">
                            <i class="bi bi-check-lg"></i> Onayla
                        </button>
                        <button class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1"
                                style="border-radius: var(--radius-sm);"
                                title="Reddet"
                                @onclick="() => OpenActionModal(item, 2)">
                            <i class="bi bi-x-lg"></i> Reddet
                        </button>
                        <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                                style="border-radius: var(--radius-sm);"
                                title="İade Et"
                                @onclick="() => OpenActionModal(item, 3)">
                            <i class="bi bi-arrow-return-left"></i> İade
                        </button>
                    </div>
                </td>
            </RowTemplate>
        </DataTable>
    </div>
</div>

@if (_isModalOpen && _selectedItem is not null)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow" style="border-radius: var(--radius-modern);">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title fw-bold">
                        @if (_selectedActionType == 1) { <i class="bi bi-check-circle-fill text-success me-2"></i> @("Onayla") }
                        else if (_selectedActionType == 2) { <i class="bi bi-x-circle-fill text-danger me-2"></i> @("Reddet") }
                        else { <i class="bi bi-arrow-return-left text-warning me-2"></i> @("İade Et") }
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseActionModal"></button>
                </div>
                <div class="modal-body bg-light">
                    <p class="mb-2 text-muted small"><strong>@_selectedItem.RequestNo</strong> numaralı talebe işlem yapıyorsunuz.</p>
                    <label class="form-label fw-semibold">
                        Yorum / Açıklama @( _selectedActionType == 1 ? "(Opsiyonel)" : "(Zorunlu)" )
                    </label>
                    <textarea class="form-control" rows="3" @bind="_actionComment" placeholder="İşlem nedenini buraya yazabilirsiniz..."></textarea>
                </div>
                <div class="modal-footer border-top bg-white">
                    <button type="button" class="btn btn-outline-secondary px-4" @onclick="CloseActionModal" disabled="@_busy">Vazgeç</button>
                    <button type="button" class="btn @GetActionBtnClass()" px-4 @onclick="ConfirmAction" disabled="@(_busy || !IsCommentValid())">
                        @if (_busy)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert mt-3 mb-0 d-flex align-items-center gap-2" style="border-radius: var(--radius-modern); background: var(--status-info-bg); color: var(--status-info); border: 1px solid rgba(59, 130, 246, 0.2);">
        <i class="bi bi-info-circle"></i> @_message
    </div>
}

@code {
    private bool _loading = true;
    private bool _busy = false;
    private string? _message;
    private IReadOnlyList<FormfleksBaseApp.Web.Models.PendingApprovalListItemDto> _items = [];

    private bool _isModalOpen;
    private FormfleksBaseApp.Web.Models.PendingApprovalListItemDto? _selectedItem;
    private int _selectedActionType;
    private string _actionComment = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        try
        {
            _items = await ApiClient.GetPendingApprovalsAsync(CancellationToken.None);
        }
        catch { /* silent */ }
        finally { _loading = false; }
    }

    private void OpenActionModal(FormfleksBaseApp.Web.Models.PendingApprovalListItemDto item, int actionType)
    {
        _selectedItem = item;
        _selectedActionType = actionType;
        _actionComment = "";
        _message = null;
        _isModalOpen = true;
    }

    private void CloseActionModal()
    {
        _isModalOpen = false;
        _selectedItem = null;
        _actionComment = "";
    }

    private bool IsCommentValid()
    {
        if (_selectedActionType == 2 || _selectedActionType == 3) // Red veya İade ise yorum zorunlu
        {
            return !string.IsNullOrWhiteSpace(_actionComment);
        }
        return true;
    }

    private string GetActionBtnClass()
    {
        return _selectedActionType switch
        {
            1 => "btn-success",
            2 => "btn-danger",
            3 => "btn-warning",
            _ => "btn-primary"
        };
    }

    private async Task ConfirmAction()
    {
        if (!TokenStore.UserId.HasValue || _selectedItem is null) return;
        if (!IsCommentValid()) return;

        _busy = true;

        try
        {
            var dto = new FormfleksBaseApp.Web.Models.ApprovalActionRequestDto
            {
                RequestId = _selectedItem.RequestId,
                ApprovalId = _selectedItem.ApprovalId,
                ActorUserId = TokenStore.UserId.Value,
                ApprovalConcurrencyToken = _selectedItem.ApprovalConcurrencyToken,
                ActionType = _selectedActionType,
                Comment = _actionComment
            };

            await ApiClient.ExecuteApprovalActionAsync(dto, CancellationToken.None);
            _message = _selectedActionType switch
            {
                1 => "Talep başarıyla onaylandı.",
                2 => "Talep reddedildi.",
                3 => "Talep revizyona iade edildi.",
                _ => "İşlem tamamlandı."
            };

            CloseActionModal();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _message = $"İşlem başarısız: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }
}
