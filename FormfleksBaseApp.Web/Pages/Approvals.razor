@page "/approvals"
@attribute [Authorize(Policy = "HasAppRole")]
@inject FormfleksBaseApp.Web.Services.ApiClient ApiClient
@inject FormfleksBaseApp.Web.Auth.AuthTokenStore TokenStore

<div class="page-header">
    <h1>Onay Bekleyenler</h1>
    <p class="page-subtitle">Size atanan bekleyen onay talepleri.</p>
</div>

<div class="card border-0 shadow-sm" style="border-radius: var(--radius-modern);">
    <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-2" style="border-radius: var(--radius-modern) var(--radius-modern) 0 0;">
        <h6 class="mb-0 fw-bold">
            <i class="bi bi-clock-history me-2" style="color: var(--brand-copper);"></i>Bekleyen Onaylar
        </h6>
        <span class="badge bg-light text-dark border">@_items.Count talep</span>
    </div>
    <div class="card-body p-0">
        <DataTable Items="_items" IsLoading="_loading" EmptyStateTitle="Tüm işlemleriniz güncel!" EmptyStateDescription="Bekleyen onay talebiniz bulunmuyor.">
            <TableHeader>
                <th>Talep No</th>
                <th>Form Tipi</th>
                <th>Adım</th>
                <th>Tarih</th>
                <th class="text-end pe-4">İşlem</th>
            </TableHeader>
            <RowTemplate Context="item">
                <td class="fw-bold">@item.RequestNo</td>
                <td>@item.FormTypeName</td>
                <td><span class="badge-status badge-approval">Adım @item.StepNo</span></td>
                <td class="text-muted small">@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td class="text-end pe-3">
                    <div class="d-flex gap-2 justify-content-end">
                        <button class="btn btn-sm btn-outline-success d-flex align-items-center gap-1" 
                                style="border-radius: var(--radius-sm);"
                                title="Onayla"
                                @onclick="() => ExecuteAction(item, 1)">
                            <i class="bi bi-check-lg"></i> Onayla
                        </button>
                        <button class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1"
                                style="border-radius: var(--radius-sm);"
                                title="Reddet"
                                @onclick="() => ExecuteAction(item, 2)">
                            <i class="bi bi-x-lg"></i> Reddet
                        </button>
                        <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                                style="border-radius: var(--radius-sm);"
                                title="İade Et"
                                @onclick="() => ExecuteAction(item, 3)">
                            <i class="bi bi-arrow-return-left"></i> İade
                        </button>
                    </div>
                </td>
            </RowTemplate>
        </DataTable>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert mt-3 mb-0 d-flex align-items-center gap-2" style="border-radius: var(--radius-modern); background: var(--status-info-bg); color: var(--status-info); border: 1px solid rgba(59, 130, 246, 0.2);">
        <i class="bi bi-info-circle"></i> @_message
    </div>
}

@code {
    private bool _loading = true;
    private string? _message;
    private IReadOnlyList<FormfleksBaseApp.Web.Models.PendingApprovalListItemDto> _items = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _items = await ApiClient.GetPendingApprovalsAsync(CancellationToken.None);
        }
        catch { /* silent */ }
        finally { _loading = false; }
    }

    private async Task ExecuteAction(FormfleksBaseApp.Web.Models.PendingApprovalListItemDto item, int actionType)
    {
        if (!TokenStore.UserId.HasValue) return;

        try
        {
            var dto = new FormfleksBaseApp.Web.Models.ApprovalActionRequestDto
            {
                RequestId = item.RequestId,
                ApprovalId = item.ApprovalId,
                ActorUserId = TokenStore.UserId.Value,
                ApprovalConcurrencyToken = item.ApprovalConcurrencyToken,
                ActionType = actionType
            };

            await ApiClient.ExecuteApprovalActionAsync(dto, CancellationToken.None);
            _message = actionType switch
            {
                1 => "Talep onaylandı.",
                2 => "Talep reddedildi.",
                3 => "Talep iade edildi.",
                _ => "İşlem tamamlandı."
            };

            _items = await ApiClient.GetPendingApprovalsAsync(CancellationToken.None);
        }
        catch (Exception ex)
        {
            _message = $"İşlem başarısız: {ex.Message}";
        }
    }
}
