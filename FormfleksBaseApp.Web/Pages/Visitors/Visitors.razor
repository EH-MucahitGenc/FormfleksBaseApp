@page "/visitors"
@using FormfleksBaseApp.Contracts.Visitors
@attribute [Authorize(Policy = "HasAppRole")]
@inject FormfleksBaseApp.Web.Services.ApiClient ApiClient

<AppPageHeader Title="Ziyaretçi Listesi" Subtitle="Firmamıza gelen ziyaretçilerin kaydı ve takibi." />

@if (_loading)
{
    <div class="d-flex justify-content-center p-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yükleniyor...</span>
        </div>
    </div>
}
else
{
    <div class="shadow-sm border rounded">
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain" CssClass="px-2 py-1 border-bottom">
            <DxToolbarItem Text="Yeni Ziyaretçi" BeginGroup="true" IconCssClass="bi bi-plus-lg" Click="OpenAddModal" />
            <DxToolbarItem Text="Sütun Seçici" BeginGroup="true" IconCssClass="bi bi-layout-three-columns" CssClass="col-chooser-btn" Click='@(() => _grid.ShowColumnChooser(".col-chooser-btn"))' />
        </DxToolbar>

        <DxGrid @ref="_grid"
                Data="@_items" 
                ShowFilterRow="true" 
                ShowGroupPanel="true" 
                ShowSearchBox="true" 
                PageSize="15" 
                PagerVisible="true" 
                PageSizeSelectorVisible="true" 
                PageSizeSelectorItems="@(new int[] { 15, 30, 50 })"
                AllowSelectRowByClick="true"
                SelectionMode="GridSelectionMode.Multiple"
                ColumnResizeMode="GridColumnResizeMode.NextColumn"
                CssClass="w-100 border-0">
            <Columns>
                <DxGridDataColumn FieldName="FirstName" Caption="Ad Soyad" MinWidth="200">
                    <CellDisplayTemplate>
                        @{ var item = (VisitorDto)context.DataItem; }
                        <span class="ff-cell-primary">@item.FirstName @item.LastName</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="CompanyName" Caption="Firma" MinWidth="250" />
                <DxGridDataColumn FieldName="Purpose" Caption="Ziyaret Nedeni" MinWidth="200" />
                <DxGridDataColumn FieldName="VisitDate" Caption="Ziyaret Tarihi" MinWidth="180">
                    <CellDisplayTemplate>
                        @{ var item = (VisitorDto)context.DataItem; }
                        <span class="ff-cell-muted">@item.VisitDate.ToString("dd.MM.yyyy HH:mm")</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>
        </DxGrid>
    </div>
}

<DxPopup Visible="@_isModalOpen" 
         VisibleChanged="@((bool v) => _isModalOpen = v)" 
         HeaderText="Yeni Ziyaretçi Ekle" 
         Width="550px" 
         ShowCloseButton="true">
    <BodyTemplate>
        <EditForm Model="_model" OnValidSubmit="HandleValidSubmit" id="visitorForm" Context="editFormCtx">
            <DataAnnotationsValidator />
            
            <DxFormLayout CssClass="w-100">
                <DxFormLayoutItem ColSpanMd="6" Caption="Ad">
                    <Template Context="formLayoutCtx">
                        <InputText @bind-Value="_model.FirstName" class="form-control" />
                        <ValidationMessage For="@(() => _model.FirstName)" />
                    </Template>
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="6" Caption="Soyad">
                    <Template Context="formLayoutCtx">
                        <InputText @bind-Value="_model.LastName" class="form-control" />
                        <ValidationMessage For="@(() => _model.LastName)" />
                    </Template>
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="12" Caption="Firma Adı">
                    <Template Context="formLayoutCtx">
                        <InputText @bind-Value="_model.CompanyName" class="form-control" />
                    </Template>
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="12" Caption="Ziyaret Nedeni">
                    <Template Context="formLayoutCtx">
                        <InputText @bind-Value="_model.Purpose" class="form-control" />
                    </Template>
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="12" Caption="Ziyaret Tarihi/Saati">
                    <Template Context="formLayoutCtx">
                        <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="_model.VisitDate" class="form-control" />
                    </Template>
                </DxFormLayoutItem>
            </DxFormLayout>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="alert alert-danger mt-3 mb-0 py-2">
                    <i class="bi bi-exclamation-triangle-fill justify-content-center me-2"></i> @_errorMessage
                </div>
            }
        </EditForm>
    </BodyTemplate>
    <FooterTemplate>
        <button type="button" class="btn btn-outline-secondary px-4" @onclick="CloseModal" disabled="@_saving">İptal</button>
        <button type="submit" form="visitorForm" class="btn btn-primary px-4 ms-2" disabled="@_saving">
            @if (_saving) { <span class="spinner-border spinner-border-sm me-2"></span> } Kaydet
        </button>
    </FooterTemplate>
</DxPopup>

@code {
    IGrid _grid;
    private bool _loading = true;
    private bool _saving = false;
    private string? _errorMessage;
    private IReadOnlyList<VisitorDto> _items = [];

    private bool _isModalOpen;
    private CreateVisitorRequestDto _model = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        try
        {
            _items = await ApiClient.GetVisitorsAsync(CancellationToken.None);
        }
        catch { /* silent */ }
        finally { _loading = false; }
    }

    private void OpenAddModal()
    {
        _model = new CreateVisitorRequestDto { VisitDate = DateTime.Now };
        _errorMessage = null;
        _isModalOpen = true;
    }

    private void CloseModal()
    {
        _isModalOpen = false;
    }

    private async Task HandleValidSubmit()
    {
        _saving = true;
        _errorMessage = null;

        var result = await ApiClient.CreateVisitorAsync(_model, CancellationToken.None);
        if (result.Success)
        {
            _isModalOpen = false;
            await LoadDataAsync();
        }
        else
        {
            _errorMessage = result.Error ?? "Bilinmeyen bir hata oluştu.";
        }

        _saving = false;
    }
}
