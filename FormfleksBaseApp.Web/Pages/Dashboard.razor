@page "/dashboard"
@attribute [Authorize(Policy = "HasAppRole")]
@inject FormfleksBaseApp.Web.Services.ApiClient ApiClient
@inject FormfleksBaseApp.Web.Auth.AuthTokenStore TokenStore

<AppPageHeader Title="@($"Hoş geldiniz, {TokenStore.UserName ?? "Kullanıcı"} 👋")" Subtitle="İş akışlarınızı ve form taleplerinizi buradan takip edebilirsiniz." />

<div class="row g-4 mb-5">
    <div class="col-sm-6 col-xl-3">
        <KpiCard Title="Toplam Formlarım" 
                 Value="@_myFormsCount.ToString()" 
                 IconClass="bi bi-file-earmark-text"
                 IconBackgroundColor="rgba(15, 98, 254, 0.1)"
                 IconColor="var(--ff-accent)"
                 Href="/my-forms" />
    </div>
    <div class="col-sm-6 col-xl-3">
        <KpiCard Title="Onay Bekleyen" 
                 Value="@_pendingCount.ToString()" 
                 IconClass="bi bi-hourglass-split"
                 IconBackgroundColor="rgba(241, 194, 27, 0.12)"
                 IconColor="var(--ff-warning)"
                 Href="/approvals" />
    </div>
    <div class="col-sm-6 col-xl-3">
        <KpiCard Title="Onaylanan" 
                 Value="@_approvedCount.ToString()" 
                 IconClass="bi bi-check-circle"
                 IconBackgroundColor="rgba(36, 161, 72, 0.12)"
                 IconColor="var(--ff-success)"
                 Href="/my-forms?status=4" />
    </div>
    <div class="col-sm-6 col-xl-3">
        <KpiCard Title="Reddedilen" 
                 Value="@_rejectedCount.ToString()" 
                 IconClass="bi bi-x-circle"
                 IconBackgroundColor="rgba(218, 30, 40, 0.12)"
                 IconColor="var(--ff-danger)"
                 Href="/my-forms?status=5" />
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius: var(--ff-border-radius-lg);">
    <div class="card-header bg-white border-bottom py-3">
        <h5 class="mb-0 fw-bold">
            <i class="bi bi-lightning-charge-fill text-warning me-2"></i>Hızlı İşlemler
        </h5>
    </div>
    <div class="card-body p-4">
        <div class="d-flex flex-wrap gap-3">
            <DxButton RenderStyle="ButtonRenderStyle.Primary"
                      RenderStyleMode="ButtonRenderStyleMode.Contained"
                      Text="Yeni İzin Talebi"
                      IconCssClass="bi bi-calendar-plus"
                      NavigateUrl="/forms/leave"
                      CssClass="px-4 py-2 fw-semibold" />
                      
            <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                      Text="Tüm Formlarım"
                      IconCssClass="bi bi-list-ul"
                      NavigateUrl="/my-forms"
                      CssClass="px-4 py-2 fw-medium border-secondary" />

            <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                      Text="Onay Bekleyenler"
                      IconCssClass="bi bi-check2-square"
                      NavigateUrl="/approvals"
                      CssClass="px-4 py-2 fw-medium border-secondary" />
        </div>
    </div>
</div>

@code {
    private int _myFormsCount;
    private int _pendingCount;
    private int _approvedCount;
    private int _rejectedCount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var myForms = await ApiClient.GetMyRequestsAsync(CancellationToken.None);
            _myFormsCount = myForms.Count;
            _approvedCount = myForms.Count(f => f.Status == 4);
            _rejectedCount = myForms.Count(f => f.Status == 5);

            var pending = await ApiClient.GetPendingApprovalsAsync(CancellationToken.None);
            _pendingCount = pending.Count;
        }
        catch { /* silent */ }
    }
}
