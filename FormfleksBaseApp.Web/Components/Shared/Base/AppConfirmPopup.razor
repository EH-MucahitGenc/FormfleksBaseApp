<DxPopup Visible="@Visible"
         VisibleChanged="OnVisibleChanged"
         HeaderText="@Title"
         Width="400px"
         ShowCloseButton="true">
    <BodyTemplate>
        <div class="text-center py-3">
            <i class="bi bi-exclamation-circle text-danger mb-3" style="font-size: 3rem;"></i>
            <p class="mb-0"><strong>@Message</strong></p>
            @if (!string.IsNullOrWhiteSpace(SubMessage))
            {
                <p class="small text-muted mt-2">@SubMessage</p>
            }
        </div>
    </BodyTemplate>
    <FooterTemplate>
        <button type="button" class="btn btn-light border" @onclick="OnCancelClick" disabled="@IsProcessing">Vazgeç</button>
        <button type="button" class="btn btn-danger px-4 ms-2" @onclick="OnConfirmClick" disabled="@IsProcessing">
            @if (IsProcessing)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            @ConfirmButtonText
        </button>
    </FooterTemplate>
</DxPopup>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }

    [Parameter] public string Title { get; set; } = "Onay Gerekli";
    [Parameter] public string Message { get; set; } = "Bu işlemi gerçekleştirmek istediğinize emin misiniz?";
    [Parameter] public string? SubMessage { get; set; }

    [Parameter] public string ConfirmButtonText { get; set; } = "Evet, Onayla";
    [Parameter] public bool IsProcessing { get; set; }

    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task OnVisibleChanged(bool value)
    {
        if (VisibleChanged.HasDelegate)
        {
            await VisibleChanged.InvokeAsync(value);
        }
        else
        {
            Visible = value;
        }
    }

    private async Task OnConfirmClick()
    {
        if (OnConfirm.HasDelegate)
        {
            await OnConfirm.InvokeAsync();
        }
    }

    private async Task OnCancelClick()
    {
        if (OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync();
        }
        else
        {
            await OnVisibleChanged(false);
        }
    }
}
