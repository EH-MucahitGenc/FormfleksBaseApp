@if (IsBooleanMode)
{
    if (Active == true)
    {
        <span class="ff-status-badge -success"><i class="bi bi-check-circle me-1" style="font-size: 0.85em;"></i> Aktif</span>
    }
    else
    {
        <span class="ff-status-badge -draft"><i class="bi bi-slash-circle me-1" style="font-size: 0.85em;"></i> Pasif</span>
    }
}
else
{
    <span class="badge-status badge-@GetStatusStyle(Status)">
        <i class="bi @GetStatusIcon(Status) me-1" style="font-size: 0.85em;"></i> @GetStatusText(Status)
    </span>
}

@code {
    [Parameter]
    public bool IsBooleanMode { get; set; } = false;

    [Parameter]
    public bool? Active { get; set; }

    [Parameter]
    public int? Status { get; set; }

    private string GetStatusText(int? status) => status switch
    {
        1 => "Taslak",
        2 => "Gönderildi",
        3 => "Onayda",
        4 => "Onaylandı",
        5 => "Reddedildi",
        6 => "İptal",
        7 => "Revizyon",
        _ => "Bilinmiyor"
    };

    private string GetStatusStyle(int? status) => status switch
    {
        1 => "draft",
        2 => "submitted",
        3 => "approval",
        4 => "approved",
        5 => "rejected",
        6 => "cancelled",
        7 => "revision",
        _ => "default"
    };

    private string GetStatusIcon(int? status) => status switch
    {
        1 => "bi-pencil",
        2 => "bi-send",
        3 => "bi-hourglass-split",
        4 => "bi-check-circle",
        5 => "bi-x-circle",
        6 => "bi-slash-circle",
        7 => "bi-arrow-counterclockwise",
        _ => "bi-question-circle"
    };
}
