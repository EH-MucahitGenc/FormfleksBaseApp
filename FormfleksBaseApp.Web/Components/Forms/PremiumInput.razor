@using System.Linq.Expressions
@inherits InputText

<div class="premium-form-group @FormGroupClass">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="premium-label">
            @if (Label.EndsWith(" *"))
            {
                @(Label.Substring(0, Label.Length - 2)) <span class="text-danger">*</span>
            }
            else
            {
                @Label
            }
        </label>
    }
    <div class="input-wrapper">
        @if (!string.IsNullOrEmpty(IconClass))
        {
            <div class="input-icon-container">
                <i class="@IconClass"></i>
            </div>
        }
        @if (Multiline)
        {
            <textarea class="premium-control dxbs-memo @(HasIcon ? "has-icon" : "") @CssClass"
                      id="@Id"
                      placeholder="@Placeholder"
                      disabled="@Disabled"
                      rows="@Rows"
                      @bind="@CurrentValueAsString"
                      @bind:event="oninput"
                      @attributes="AdditionalAttributes"></textarea>
        }
        else
        {
            var baseTypeClass = Type == "date" ? "dxbs-date-edit" 
                              : Type == "time" ? "dxbs-time-edit" 
                              : "dxbs-textbox";
                              
            <input class="premium-control @baseTypeClass @(HasIcon ? "has-icon" : "") @CssClass"
                   id="@Id"
                   placeholder="@Placeholder"
                   type="@Type"
                   disabled="@Disabled"
                   @bind="@CurrentValueAsString"
                   @bind:event="oninput"
                   @attributes="AdditionalAttributes" />
        }
    </div>
    
    <div class="premium-validation-container">
        <ValidationMessage For="@ValueExpression" class="premium-validation" />
        @if (!string.IsNullOrEmpty(HelperText))
        {
            <span class="premium-helper-text">@HelperText</span>
        }
    </div>
</div>

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? IconClass { get; set; }
    [Parameter] public string Type { get; set; } = "text";
    [Parameter] public string? Id { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? FormGroupClass { get; set; }
    [Parameter] public bool Multiline { get; set; }
    [Parameter] public int Rows { get; set; } = 3;

    private bool HasIcon => !string.IsNullOrEmpty(IconClass);
}
