@inherits InputBase<string>

<div class="premium-form-group @FormGroupClass">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="premium-label">
            @if (Label.EndsWith(" *"))
            {
                @(Label.Substring(0, Label.Length - 2)) <span class="text-danger">*</span>
            }
            else
            {
                @Label
            }
        </label>
    }

    <div class="input-wrapper">
        @if (!string.IsNullOrEmpty(IconClass))
        {
            <div class="input-icon-container">
                <i class="@IconClass"></i>
            </div>
        }

        <select class="premium-control premium-select @(HasIcon ? "has-icon" : "") @CssClass"
                id="@Id"
                disabled="@Disabled"
                value="@CurrentValue"
                @onchange="OnChange"
                @attributes="AdditionalAttributes">
            
            @if (!string.IsNullOrEmpty(Placeholder))
            {
                <option value="" disabled selected="@string.IsNullOrWhiteSpace(CurrentValue)">@Placeholder</option>
            }
            
            @if (Options != null)
            {
                foreach (var opt in Options)
                {
                    <option value="@opt.Value">@opt.Text</option>
                }
            }
            else
            {
                @ChildContent
            }
        </select>
        <div class="select-arrow">
            <i class="bi bi-chevron-down"></i>
        </div>
    </div>
    
    <div class="premium-validation-container">
        <ValidationMessage For="@ValueExpression" class="premium-validation" />
        @if (!string.IsNullOrEmpty(HelperText))
        {
            <span class="premium-helper-text">@HelperText</span>
        }
    </div>
</div>

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; } = "Seçiniz";
    [Parameter] public string? IconClass { get; set; }
    [Parameter] public string? Id { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? FormGroupClass { get; set; }
    [Parameter] public IEnumerable<OptionItemDto>? Options { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool HasIcon => !string.IsNullOrEmpty(IconClass);

    protected override bool TryParseValueFromString(string? value, out string result, out string validationErrorMessage)
    {
        result = value ?? string.Empty;
        validationErrorMessage = null!;
        return true;
    }

    private void OnChange(ChangeEventArgs e)
    {
        CurrentValueAsString = e.Value?.ToString();
    }

    public class OptionItemDto
    {
        public string Value { get; set; } = string.Empty;
        public string Text { get; set; } = string.Empty;
    }
}
