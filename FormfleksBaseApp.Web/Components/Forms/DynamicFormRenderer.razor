@using FormfleksBaseApp.Web.Models

@if (FormDefinition is not null)
{
    <div class="google-form-container">


        @foreach (var formSection in (FormDefinition.Sections ?? []).OrderBy(x => x.SortOrder))
        {
            <h4 class="google-form-section-title">
                <i class="bi bi-card-text"></i> @formSection.Title
            </h4>

            <div class="row g-4">
                @foreach (var field in (formSection.Fields ?? []).Where(f => !string.IsNullOrWhiteSpace(f.Key)).OrderBy(x => x.SortOrder))
                {
                    <div class="@GetColClass(field)">
                        @switch (field.FieldType)
                        {
                            case 2: // Textarea
                                <PremiumInput Label="@GetLabel(field)"
                                              @bind-Value="GetBindValue(field.Key).Value"
                                              Placeholder="@field.Placeholder"
                                              Multiline="true"
                                              Rows="3"
                                              HelpText="@field.HelpText" />
                                break;
                            case 7: // Select (Dropdown)
                                {
                                    var options = ParseOptions(field.OptionsJson);
                                    <PremiumSelect Label="@GetLabel(field)"
                                                   @bind-Value="GetBindValue(field.Key).Value"
                                                   Placeholder="@field.Placeholder"
                                                   Options="options"
                                                   HelpText="@field.HelpText" />
                                }
                                break;
                            case 8: // Radio (Rendering as Select for UI consistency right now, or you can build PremiumRadio later)
                                {
                                    var options = ParseOptions(field.OptionsJson);
                                    <PremiumSelect Label="@GetLabel(field)"
                                                   @bind-Value="GetBindValue(field.Key).Value"
                                                   Placeholder="@field.Placeholder"
                                                   Options="options"
                                                   HelpText="@field.HelpText" />
                                }
                                break;
                            case 9: // Checkbox
                                <PremiumCheckbox Label="@GetLabel(field)"
                                                 Value="@GetBoolValue(field.Key)"
                                                 ValueChanged="val => SetBoolValue(field.Key, val)"
                                                 ValueExpression="() => _dummyBool" 
                                                 HelpText="@field.HelpText" />
                                break;
                            case 4: // Date
                                <PremiumInput Label="@GetLabel(field)"
                                              @bind-Value="GetBindValue(field.Key).Value"
                                              Type="date"
                                              IconClass="bi bi-calendar"
                                              HelpText="@field.HelpText" />
                                break;
                            case 5: // DateTime
                                <PremiumInput Label="@GetLabel(field)"
                                              @bind-Value="GetBindValue(field.Key).Value"
                                              Type="datetime-local"
                                              IconClass="bi bi-clock-history"
                                              HelpText="@field.HelpText" />
                                break;
                            case 6: // Time
                                <PremiumInput Label="@GetLabel(field)"
                                              @bind-Value="GetBindValue(field.Key).Value"
                                              Type="time"
                                              IconClass="bi bi-clock"
                                              HelpText="@field.HelpText" />
                                break;
                            case 3: // Number
                                <PremiumInput Label="@GetLabel(field)"
                                              @bind-Value="GetBindValue(field.Key).Value"
                                              Type="number"
                                              IconClass="bi bi-123"
                                              Placeholder="@field.Placeholder"
                                              HelpText="@field.HelpText" />
                                break;
                            default: // (1) Text
                                <PremiumInput Label="@GetLabel(field)"
                                              @bind-Value="GetBindValue(field.Key).Value"
                                              Type="text"
                                              IconClass="bi bi-cursor-text"
                                              Placeholder="@field.Placeholder"
                                              HelpText="@field.HelpText" />
                                break;
                        }
                    </div>
                }
            </div>
        }
    </div>
}
else
{
    <div>No form definition provided.</div>
}

@code {
    [Parameter, EditorRequired]
    public FormDefinitionDto? FormDefinition { get; set; }

    [Parameter, EditorRequired]
    public Dictionary<string, string?> FormValues { get; set; } = new(StringComparer.OrdinalIgnoreCase);

    private bool _dummyBool = false; 

    private string GetLabel(FormFieldDto field)
    {
        return field.Label + (field.IsRequired ? " *" : "");
    }

    private string GetColClass(FormFieldDto field)
    {
        return field.FieldType == 2 ? "col-12" : "col-md-6 col-xl-4"; // textareas make 100% width
    }

    private BindableValue GetBindValue(string key)
    {
        return new BindableValue(this, key);
    }

    private class BindableValue
    {
        private readonly DynamicFormRenderer _parent;
        private readonly string _key;

        public BindableValue(DynamicFormRenderer parent, string key)
        {
            _parent = parent;
            _key = key;
        }

        public string Value
        {
            get => _parent.FormValues.TryGetValue(_key, out var val) ? (val ?? "") : "";
            set => _parent.FormValues[_key] = value;
        }
    }

    private bool GetBoolValue(string key)
    {
        return FormValues.TryGetValue(key, out var val) &&
               (string.Equals(val, "true", StringComparison.OrdinalIgnoreCase) || val == "1");
    }

    private void SetBoolValue(string key, bool value)
    {
        FormValues[key] = value ? "true" : "false";
    }

    private IEnumerable<PremiumSelect.OptionItemDto> ParseOptions(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return Enumerable.Empty<PremiumSelect.OptionItemDto>();
        try
        {
            var opts = System.Text.Json.JsonSerializer.Deserialize<List<PremiumSelect.OptionItemDto>>(json);
            return opts ?? Enumerable.Empty<PremiumSelect.OptionItemDto>();
        }
        catch
        {
            return Enumerable.Empty<PremiumSelect.OptionItemDto>();
        }
    }
}
