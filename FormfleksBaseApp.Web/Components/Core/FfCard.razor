<div class="premium-card @Class">
    @if (HeaderContent is not null || !string.IsNullOrWhiteSpace(Title))
    {
        <div class="@(GradientHeader ? "premium-card-header-gradient" : "premium-card-header")">
            @if (HeaderContent is not null)
            {
                @HeaderContent
            }
            else
            {
                <h5 class="mb-0 fw-bold">@Title</h5>
            }
        </div>
    }
    <div class="premium-card-body @BodyClass">
        @ChildContent
    </div>
</div>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? HeaderContent { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string Class { get; set; } = "";
    [Parameter] public string BodyClass { get; set; } = "";
    [Parameter] public bool GradientHeader { get; set; } = false;
}
