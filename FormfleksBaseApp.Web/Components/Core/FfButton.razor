<button type="@Type" class="btn @GetVariantClass() @Class" disabled="@Disabled" @onclick="OnClick">
    @if (IsLoading)
    {
        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
        @LoadingText
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(Icon))
        {
            <i class="@Icon me-2"></i>
        }
        @ChildContent
    }
</button>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string Type { get; set; } = "button";
    [Parameter] public string Variant { get; set; } = "primary"; // primary, secondary, outline, text
    [Parameter] public string Class { get; set; } = "";
    [Parameter] public string? Icon { get; set; }
    [Parameter] public bool Disabled { get; set; } = false;
    [Parameter] public bool IsLoading { get; set; } = false;
    [Parameter] public string LoadingText { get; set; } = "Lütfen bekleyin...";
    [Parameter] public EventCallback<Microsoft.AspNetCore.Components.Web.MouseEventArgs> OnClick { get; set; }

    private string GetVariantClass()
    {
        return Variant.ToLower() switch
        {
            "primary" => "btn-brand",
            "secondary" => "btn-secondary text-white",
            "outline" => "btn-outline-secondary",
            "danger" => "btn-danger text-white",
            "text" => "btn-link text-decoration-none text-muted-custom",
            _ => "btn-brand"
        };
    }
}
