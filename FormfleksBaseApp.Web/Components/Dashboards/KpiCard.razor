@inject NavigationManager Navigation

<div class="card border-0 shadow-sm h-100 @CssClass @(!string.IsNullOrEmpty(Href) ? "position-relative" : "")" 
     @onclick="HandleClick" 
     style="border-radius: var(--ff-border-radius-lg); overflow: hidden; @(!string.IsNullOrEmpty(Href) ? "cursor: pointer; transition: transform 0.2s ease, box-shadow 0.2s ease;" : "")">
    <div class="card-body p-4 d-flex flex-column justify-content-between h-100">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <h6 class="text-muted text-uppercase fw-bold mb-0" style="font-size: 0.8rem; letter-spacing: 0.5px;">@Title</h6>
            @if (!string.IsNullOrEmpty(IconClass))
            {
                <div class="d-flex align-items-center justify-content-center rounded-3" 
                     style="width: 42px; height: 42px; background-color: @IconBackgroundColor; color: @IconColor;">
                    <i class="@IconClass fs-5"></i>
                </div>
            }
        </div>
        <div>
            <h3 class="fw-bold mb-0" style="color: var(--ff-text-main); font-size: 2rem;">@Value</h3>
            @if (!string.IsNullOrEmpty(Subtitle))
            {
                <div class="text-muted small mt-2">@Subtitle</div>
            }
        </div>
    </div>
    @if (!string.IsNullOrEmpty(Href))
    {
        <a href="@Href" class="stretched-link"></a>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "Title";
    [Parameter] public string Value { get; set; } = "0";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public string? IconClass { get; set; }
    
    [Parameter] public string IconBackgroundColor { get; set; } = "rgba(240, 138, 75, 0.15)";
    [Parameter] public string IconColor { get; set; } = "#F08A4B"; // Brand Copper

    [Parameter] public string? CssClass { get; set; }
    [Parameter] public string? Href { get; set; }

    private void HandleClick()
    {
        if (!string.IsNullOrEmpty(Href))
        {
            Navigation.NavigateTo(Href);
        }
    }
}
