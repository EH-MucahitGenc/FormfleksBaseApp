@typeparam TItem

<div class="premium-table-container">
    <div class="table-responsive">
        <table class="table premium-table mb-0">
            <thead>
                <tr>
                    @TableHeader
                </tr>
            </thead>
            <tbody>
                @if (IsLoading)
                {
                    <tr>
                        <td colspan="100%" class="text-center py-5">
                            <div class="spinner-border text-brand" role="status"></div>
                            <div class="mt-3 table-loading-text">Veriler yükleniyor...</div>
                        </td>
                    </tr>
                }
                else if (Items == null || !Items.Any())
                {
                    <tr>
                        <td colspan="100%" class="text-center py-5">
                            <i class="bi bi-inbox table-empty-icon"></i>
                            <h5 class="table-empty-title">@EmptyStateTitle</h5>
                            <p class="table-empty-desc">@EmptyStateDescription</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Items)
                    {
                        <tr class="premium-row">
                            @RowTemplate!(item)
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter] public IEnumerable<TItem>? Items { get; set; }
    [Parameter] public RenderFragment? TableHeader { get; set; }
    [Parameter] public RenderFragment<TItem>? RowTemplate { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    
    [Parameter] public string EmptyStateTitle { get; set; } = "Kayıt Bulunamadı";
    [Parameter] public string EmptyStateDescription { get; set; } = "Gösterilecek herhangi bir veri bulunmuyor.";
}
