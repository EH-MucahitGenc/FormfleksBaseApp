<header class="ff-topbar shadow-sm" style="background-color: var(--ff-topbar-bg); border-bottom: 1px solid var(--ff-topbar-border);">
    <div class="d-flex align-items-center w-100 h-100">
        
        <!-- Left: Brand Lockup & Sidebar Toggle -->
        <div class="d-flex align-items-center h-100" style="width: @(IsCollapsed ? "80px" : "var(--ff-sidebar-width)"); flex-shrink: 0; padding-left: @(IsCollapsed ? "1.2rem" : "1.5rem"); border-right: 1px solid var(--ff-border); transition: width 0.3s cubic-bezier(0.2, 0, 0, 1), padding 0.3s ease; overflow: hidden;">
            <button class="btn btn-sm btn-light border-0 me-3 d-flex align-items-center justify-content-center flex-shrink-0" @onclick="OnToggleSidebar" aria-label="Menüyü daralt/aç" 
                    style="width: 32px; height: 32px; background: var(--ff-bg-body); color: var(--ff-text-secondary); border-radius: var(--ff-border-radius);">
                <i class="bi bi-list fs-5"></i>
            </button>
            
            <!-- Logo area hidden when collapsed to prevent overflow visually breaking -->
            <a href="/dashboard" class="d-flex align-items-center text-decoration-none bg-white" style="opacity: @(IsCollapsed ? "0" : "1"); transition: opacity 0.2s ease;">
                <img src="/images/logo.svg" alt="Logo" style="height: 24px;" />
            </a>
        </div>

        <!-- Middle: Context / Title -->
        <div class="flex-grow-1 px-4 d-flex align-items-center">
            <nav aria-label="breadcrumb">
              <ol class="breadcrumb mb-0" style="font-size: 0.9rem; font-weight: 500;">
                <li class="breadcrumb-item"><a href="/dashboard" style="color: var(--ff-text-muted);"><i class="bi bi-house-door"></i></a></li>
                <li class="breadcrumb-item active" aria-current="page" style="color: var(--ff-text-main);">@Title</li>
              </ol>
            </nav>
        </div>

        <!-- Right: User Actions -->
        <div class="d-flex align-items-center pe-4 gap-3">
            
            <button class="btn btn-sm position-relative d-flex align-items-center justify-content-center" title="Bildirimler" 
                    style="width: 40px; height: 40px; border-radius: 50%; color: var(--ff-text-secondary); background: transparent;">
                <i class="bi bi-bell fs-5"></i>
                <span class="position-absolute top-0 start-100 translate-middle p-1 rounded-circle" style="background-color: var(--ff-primary); margin-top: 10px; margin-left: -12px;">
                    <span class="visually-hidden">Yeni bildirim</span>
                </span>
            </button>

            @if (!string.IsNullOrEmpty(UserName))
            {
                <div class="d-flex align-items-center gap-2 px-2 py-1" style="background-color: var(--ff-bg-body); border-radius: 50px; border: 1px solid var(--ff-border); cursor: pointer; transition: background 0.2s;">
                    <div class="d-flex justify-content-center align-items-center fw-bold" 
                         style="width: 32px; height: 32px; border-radius: 50%; background-color: var(--ff-primary-soft); color: var(--ff-primary);">
                        @(UserName.Substring(0, 1).ToUpper())
                    </div>
                    <div class="d-none d-sm-flex flex-column pe-3" style="line-height:1.2;">
                        <span class="fw-bold" style="color: var(--ff-text-main); font-size: 0.85rem;">@UserName</span>
                        <span style="color: var(--ff-text-muted); font-size: 0.75rem;">@(string.IsNullOrWhiteSpace(UserRole) ? "Kullanıcı" : UserRole)</span>
                    </div>
                    <button class="btn btn-sm p-0 text-muted me-2" @onclick="OnLogout" title="Çıkış" style="background:transparent; border:none;">
                        <i class="bi bi-power fs-5" style="color: var(--ff-danger);"></i>
                    </button>
                </div>
            }
        </div>
    </div>
</header>

@code {
    [Parameter]
    public string? UserName { get; set; }

    [Parameter]
    public string? UserRole { get; set; }

    [Parameter]
    public string Title { get; set; } = "İnsan Kaynakları Form Takip";

    [Parameter]
    public bool IsCollapsed { get; set; }

    [Parameter]
    public EventCallback OnToggleSidebar { get; set; }

    [Parameter]
    public EventCallback OnLogout { get; set; }
}
