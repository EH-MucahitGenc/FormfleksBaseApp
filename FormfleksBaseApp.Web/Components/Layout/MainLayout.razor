@inherits LayoutComponentBase
@inject FormfleksBaseApp.Web.Auth.AuthTokenStore TokenStore
@inject FormfleksBaseApp.Web.Auth.AppAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject FormfleksBaseApp.Web.Services.ApiClient ApiClient

<div class="app-shell">
    <AppSidebar IsCollapsed="_isSidebarCollapsed"
                FormTypes="_formTypes"
                HasAppRole="HasAppRole"
                CanAccessTemplateAdmin="CanAccessTemplateAdmin"
                CanAccessUserAdmin="CanAccessUserAdmin" />

    <div class="app-main @(_isSidebarCollapsed ? "sidebar-collapsed" : "")">
        <AppTopbar Title="İnsan Kaynakları Form Takip"
                   UserName="@TokenStore.UserName"
                   UserRole="@(TokenStore.Roles.Count > 0 ? TokenStore.Roles[0] : "Yetkisiz")"
                   OnToggleSidebar="ToggleSidebar"
                   OnLogout="Logout" />

        <main class="page-content">
            <div class="content-container">
                @Body
            </div>
        </main>
    </div>
</div>

@code {
    [CascadingParameter]
    private Task<Microsoft.AspNetCore.Components.Authorization.AuthenticationState> AuthState { get; set; } = default!;

    private bool _isSidebarCollapsed;
    private IReadOnlyList<FormfleksBaseApp.Web.Models.FormTemplateSummaryDto>? _formTypes;

    private bool HasAppRole => TokenStore.Roles.Count > 0;
    private bool CanAccessTemplateAdmin =>
        TokenStore.Roles.Any(x => string.Equals(x, "Admin", StringComparison.OrdinalIgnoreCase) ||
                                  string.Equals(x, "HR", StringComparison.OrdinalIgnoreCase));
    private bool CanAccessUserAdmin =>
        TokenStore.Roles.Any(x => string.Equals(x, "Admin", StringComparison.OrdinalIgnoreCase));

    protected override async Task OnParametersSetAsync()
    {
        if (_formTypes is null)
        {
            var state = await AuthState;
            if (state.User.Identity?.IsAuthenticated == true && HasAppRole)
            {
                try
                {
                    var all = await ApiClient.GetTemplatesAsync(CancellationToken.None);
                    if (all is not null)
                    {
                        _formTypes = all;
                        StateHasChanged();
                    }
                }
                catch
                {
                    // silent
                }
            }
        }
    }

    private void ToggleSidebar() => _isSidebarCollapsed = !_isSidebarCollapsed;

    private async Task Logout()
    {
        await AuthStateProvider.MarkLoggedOutAsync();
        Navigation.NavigateTo("/login", forceLoad: false);
    }
}
