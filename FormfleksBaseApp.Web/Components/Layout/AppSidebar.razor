@using Microsoft.AspNetCore.Components.Routing
@using System.Linq

<div class="ff-sidebar @(IsCollapsed ? "collapsed" : "") ff-sidebar-dx-wrapper h-100 overflow-auto" style="border-right: 1px solid var(--ff-border); background-color: var(--ff-sidebar-bg);">
    <DxTreeView AllowSelectNodes="true" AnimationType="TreeViewAnimationType.Slide" CssClass="w-100 mt-2 ff-main-treeview">
        <Nodes>
            @if (HasAppRole)
            {
                <DxTreeViewNode NavigateUrl="/dashboard" Text="Panel" IconCssClass="bi bi-grid-1x2-fill" CssClass="fw-medium mb-1 px-2" />
                <DxTreeViewNode NavigateUrl="/my-forms" Text="Formlarım" IconCssClass="bi bi-file-earmark-text" CssClass="fw-medium mb-1 px-2" />
                <DxTreeViewNode NavigateUrl="/approvals" Text="Onay Bekleyenler" IconCssClass="bi bi-check2-square" CssClass="fw-medium mb-1 px-2" />
                <DxTreeViewNode NavigateUrl="/visitors" Text="Ziyaretçiler" IconCssClass="bi bi-person-lines-fill" CssClass="fw-medium mb-1 px-2" />
                
                @if (FormTypes is not null && FormTypes.Any(x => x.Active))
                {
                    <DxTreeViewNode Text="Açılabilir Formlar" IconCssClass="bi bi-folder-fill" Expanded="true" CssClass="fw-medium mb-1 px-2">
                        <Nodes>
                            @foreach (var ft in FormTypes.Where(x => x.Active))
                            {
                                <DxTreeViewNode NavigateUrl="@($"/forms/{ft.Code.ToLowerInvariant()}")" Text="@ft.Name" IconCssClass="bi bi-pencil-square" CssClass="fw-medium mb-1" />
                            }
                        </Nodes>
                    </DxTreeViewNode>
                }
            }

            @if (CanAccessTemplateAdmin || CanAccessUserAdmin)
            {
                <DxTreeViewNode Text="Yönetim" IconCssClass="bi bi-gear-fill" Expanded="true" CssClass="fw-medium mb-1 px-2 mt-3 border-top pt-2">
                    <Nodes>
                        @if (CanAccessTemplateAdmin)
                        {
                            <DxTreeViewNode NavigateUrl="/admin/form-designer" Text="Form Tasarımcısı" IconCssClass="bi bi-columns-gap" CssClass="fw-medium mb-1" />
                            <DxTreeViewNode NavigateUrl="/admin/workflow-designer" Text="Onay Rotaları" IconCssClass="bi bi-diagram-3" CssClass="fw-medium mb-1" />
                            <DxTreeViewNode NavigateUrl="/admin/audit-logs" Text="Eylem Geçmişi" IconCssClass="bi bi-shield-check" CssClass="fw-medium mb-1" />
                        }

                        @if (CanAccessUserAdmin)
                        {
                            <DxTreeViewNode NavigateUrl="/admin/users" Text="Kullanıcı Yönetimi" IconCssClass="bi bi-people" CssClass="fw-medium mb-1" />
                            <DxTreeViewNode NavigateUrl="/admin/roles" Text="Rol Yönetimi" IconCssClass="bi bi-shield-lock" CssClass="fw-medium mb-1" />
                            <DxTreeViewNode NavigateUrl="/admin/departments" Text="Departman Yönetimi" IconCssClass="bi bi-building" CssClass="fw-medium mb-1" />
                        }
                    </Nodes>
                </DxTreeViewNode>
            }
        </Nodes>
    </DxTreeView>
</div>

@code {
    [Parameter]
    public bool IsCollapsed { get; set; }

    [Parameter]
    public IReadOnlyList<FormfleksBaseApp.Web.Models.FormTemplateSummaryDto>? FormTypes { get; set; }

    [Parameter]
    public bool HasAppRole { get; set; }

    [Parameter]
    public bool CanAccessTemplateAdmin { get; set; }

    [Parameter]
    public bool CanAccessUserAdmin { get; set; }

    private bool _formsExpanded = true;

    private void ToggleForms()
    {
        _formsExpanded = !_formsExpanded;
    }
}
