@using Microsoft.AspNetCore.Components.Routing
@using System.Linq

<div class="sidebar @(IsCollapsed ? "collapsed" : "")">
    <div class="sidebar-header d-flex justify-content-center align-items-center">
        <a href="/dashboard">
            <img src="/images/logo.png" alt="İnsan Kaynakları Form Takip" class="sidebar-logo" style="max-height: 38px;" />
        </a>
    </div>

    <div class="sidebar-content">
        @if (HasAppRole)
        {
            <p class="nav-section-title @(IsCollapsed ? "d-none" : "")">Ana Menü</p>

            <NavLink class="app-nav-link" href="/dashboard" Match="NavLinkMatch.All" title="Panel">
                <i class="bi bi-grid-1x2-fill nav-icon"></i>
                <span class="nav-text @(IsCollapsed ? "d-none" : "")">Panel</span>
            </NavLink>

            <NavLink class="app-nav-link" href="/my-forms" title="Formlarım">
                <i class="bi bi-file-earmark-text nav-icon"></i>
                <span class="nav-text @(IsCollapsed ? "d-none" : "")">Formlarım</span>
            </NavLink>

            <NavLink class="app-nav-link" href="/approvals" title="Onay Bekleyenler">
                <i class="bi bi-check2-square nav-icon"></i>
                <span class="nav-text @(IsCollapsed ? "d-none" : "")">Onay Bekleyenler</span>
            </NavLink>

            <hr class="nav-divider" />
        }

        @if (CanAccessTemplateAdmin || CanAccessUserAdmin)
        {
            <p class="nav-section-title @(IsCollapsed ? "d-none" : "")">Yönetim</p>

            @if (CanAccessTemplateAdmin)
            {
                <NavLink class="app-nav-link" href="/admin/form-designer" title="Form Tasarımcısı">
                    <i class="bi bi-columns-gap nav-icon"></i>
                    <span class="nav-text @(IsCollapsed ? "d-none" : "")">Form Tasarımcısı</span>
                </NavLink>

                <NavLink class="app-nav-link" href="/admin/workflow-designer" title="Onay Rotaları">
                    <i class="bi bi-diagram-3 nav-icon"></i>
                    <span class="nav-text @(IsCollapsed ? "d-none" : "")">Onay Rotaları</span>
                </NavLink>
            }

            @if (CanAccessUserAdmin)
            {
                <NavLink class="app-nav-link" href="/admin/users" title="Kullanıcı Yönetimi">
                    <i class="bi bi-people nav-icon"></i>
                    <span class="nav-text @(IsCollapsed ? "d-none" : "")">Kullanıcı Yönetimi</span>
                </NavLink>
            }

            <hr class="nav-divider" />
        }

        @if (HasAppRole)
        {
            <p class="nav-section-title @(IsCollapsed ? "d-none" : "")">Formlar</p>

            @if (FormTypes is not null)
            {
                foreach (var ft in FormTypes.Where(x => x.Active))
                {
                    <NavLink class="app-nav-link" href="@($"/forms/{ft.Code.ToLower()}")" title="@ft.Name">
                        <i class="bi bi-pencil-square nav-icon"></i>
                        <span class="nav-text @(IsCollapsed ? "d-none" : "")">@ft.Name</span>
                    </NavLink>
                }
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public bool IsCollapsed { get; set; }

    [Parameter]
    public IReadOnlyList<FormfleksBaseApp.Web.Models.FormTemplateSummaryDto>? FormTypes { get; set; }

    [Parameter]
    public bool HasAppRole { get; set; }

    [Parameter]
    public bool CanAccessTemplateAdmin { get; set; }

    [Parameter]
    public bool CanAccessUserAdmin { get; set; }
}
